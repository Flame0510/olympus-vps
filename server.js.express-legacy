// GET /api/metrics?limit=60&range=24h — system metrics (CPU, RAM, disk)
app.get('/api/metrics', requireAuth, (req, res) => {
  try {
    const limit = Math.min(parseInt(req.query.limit) || 60, 1000);
    const range = req.query.range || '24h';
    const rangeSeconds = range === '7d' ? 7*24*3600 : range === '1h' ? 3600 : 24*3600;
    const since = Math.floor(Date.now() / 1000) - rangeSeconds;

    const db = getDb();

    const latest = db.prepare(
      'SELECT cpu_percent as cpu, ram_used_mb, ram_total_mb, disk_used_gb, disk_total_gb, load_avg_1m as load_avg, ts FROM system_metrics ORDER BY ts DESC LIMIT 1'
    ).get();

    const history = db.prepare(
      'SELECT cpu_percent as cpu, ram_used_mb, ram_total_mb, disk_used_gb, disk_total_gb, load_avg_1m as load_avg, ts FROM system_metrics ORDER BY ts DESC LIMIT ?'
    ).all(limit);

    const stats = db.prepare(`
      SELECT
        ROUND(AVG(cpu_percent)) as cpu_avg,
        MAX(cpu_percent) as cpu_max,
        ROUND(AVG(ram_used_mb)) as ram_avg_mb,
        MAX(ram_used_mb) as ram_max_mb
      FROM system_metrics WHERE ts >= ?
    `).get(since);

    db.close();
    res.json({
      latest: latest || null,
      history: history.reverse(), // chronological order
      stats_24h: {
        cpu_avg: stats?.cpu_avg || 0,
        cpu_max: stats?.cpu_max || 0,
        ram_avg_mb: stats?.ram_avg_mb || 0,
        ram_max_mb: stats?.ram_max_mb || 0,
      }
    });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

