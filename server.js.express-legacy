// GET /api/tool-calls?session_id=xxx&limit=50 — tool call tracing
app.get('/api/tool-calls', requireAuth, (req, res) => {
  try {
    const limit = Math.min(parseInt(req.query.limit) || 50, 200);
    const sessionId = req.query.session_id;
    const db = getDb();
    let rows;
    if (sessionId) {
      rows = db.prepare(
        'SELECT * FROM tool_calls WHERE session_id = ? ORDER BY ts DESC LIMIT ?'
      ).all(sessionId, limit);
    } else {
      rows = db.prepare(
        'SELECT * FROM tool_calls ORDER BY ts DESC LIMIT ?'
      ).all(limit);
    }
    db.close();
    res.json(rows);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

