<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>👁️ OLYMPUS — Agency Monitor</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0A0A0B;
    --bg2: #111114;
    --bg3: #18181c;
    --copper: #B87333;
    --copper-dim: #7a4d22;
    --text: #E8E8E8;
    --text-dim: #888;
    --green: #22c55e;
    --red: #ef4444;
    --gray: #4b5563;
    --border: #222228;
  }

  html, body { height: 100%; background: var(--bg); color: var(--text); font-family: 'JetBrains Mono', monospace; overflow: hidden; }

  /* HEADER */
  #header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 20px;
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
    height: 48px;
  }
  #header .logo { display: flex; align-items: center; gap: 10px; }
  #header .logo span.eye { font-size: 20px; }
  #header .logo span.title { font-family: 'Instrument Serif', serif; font-size: 20px; letter-spacing: 4px; color: var(--copper); }
  #header .meta { display: flex; gap: 24px; font-size: 11px; color: var(--text-dim); }
  #header .meta .val { color: var(--text); font-weight: 500; }
  #header .meta .cost-val { color: var(--copper); font-weight: 700; }

  /* AGENT FILTER TOOLBAR */
  #agent-toolbar {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
    overflow-x: auto;
    flex-shrink: 0;
  }
  #agent-toolbar::-webkit-scrollbar { height: 3px; }
  #agent-toolbar::-webkit-scrollbar-thumb { background: var(--copper-dim); border-radius: 2px; }
  .agent-filter-label {
    font-size: 9px; letter-spacing: 2px; color: var(--text-dim); text-transform: uppercase;
    white-space: nowrap; margin-right: 4px;
  }
  .agent-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    padding: 3px 10px;
    border: 1px solid var(--border);
    background: var(--bg3);
    color: var(--text-dim);
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .agent-btn:hover { border-color: var(--copper-dim); color: var(--text); }
  .agent-btn.active { border-color: var(--copper); color: var(--copper); background: #1a1208; }

  /* MAIN LAYOUT */
  #main {
    display: grid;
    grid-template-columns: 1fr 360px;
    height: calc(100vh - 48px - 34px);
  }

  /* GRAPH PANEL */
  #graph-panel {
    border-right: 1px solid var(--border);
    overflow: hidden;
    position: relative;
    background: var(--bg);
    display: flex; flex-direction: column;
  }
  #graph-panel .panel-title {
    padding: 8px 16px;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--copper);
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
    text-transform: uppercase;
    flex-shrink: 0;
  }
  #graph-svg { width: 100%; flex: 1; }

  /* TOOLTIP */
  #tooltip {
    position: fixed;
    background: var(--bg3);
    border: 1px solid var(--copper-dim);
    border-radius: 4px;
    padding: 10px 14px;
    font-size: 11px;
    display: none;
    z-index: 100;
    max-width: 320px;
    pointer-events: none;
  }
  #tooltip .tt-id { color: var(--copper); font-weight: 700; margin-bottom: 4px; word-break: break-all; }
  #tooltip .tt-row { color: var(--text-dim); line-height: 1.8; }
  #tooltip .tt-row span { color: var(--text); }

  /* TASK PREVIEW */
  #task-panel {
    position: absolute;
    bottom: 16px; left: 16px;
    max-width: 340px;
    background: var(--bg3);
    border: 1px solid var(--copper-dim);
    border-radius: 4px;
    padding: 12px;
    font-size: 11px;
    display: none;
    z-index: 10;
  }
  #task-panel .tp-label { color: var(--copper); font-weight: 700; margin-bottom: 6px; }
  #task-panel .tp-text { color: var(--text-dim); line-height: 1.5; }
  #task-panel .tp-close { float: right; cursor: pointer; color: var(--text-dim); }

  /* RIGHT PANEL */
  #right-panel {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg);
  }

  /* LIVE FEED */
  #feed-panel {
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  #feed-panel .panel-title {
    padding: 8px 16px;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--copper);
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
    text-transform: uppercase;
  }
  #feed-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
  }
  #feed-list::-webkit-scrollbar { width: 4px; }
  #feed-list::-webkit-scrollbar-track { background: var(--bg2); }
  #feed-list::-webkit-scrollbar-thumb { background: var(--copper-dim); border-radius: 2px; }
  .feed-item {
    padding: 5px 16px;
    font-size: 10px;
    line-height: 1.4;
    border-bottom: 1px solid var(--border);
  }
  .feed-item .fi-ts { color: var(--text-dim); margin-right: 8px; }
  .feed-item .fi-type { color: var(--copper); margin-right: 6px; font-weight: 700; }
  .feed-item .fi-label { color: var(--text); }
  .fi-type.spawn { color: var(--green); }
  .fi-type.complete { color: #60a5fa; }
  .fi-type.error { color: var(--red); }
  .fi-type.tool_call { color: #a78bfa; }

  /* COST BREAKDOWN */
  #cost-panel {
    border-top: 1px solid var(--border);
    padding: 12px 16px;
    background: var(--bg2);
    font-size: 11px;
  }
  #cost-panel .panel-title {
    font-size: 10px; letter-spacing: 2px; color: var(--copper);
    text-transform: uppercase; margin-bottom: 10px;
  }
  #cost-rows { display: flex; flex-wrap: wrap; gap: 8px 24px; }
  .cost-row { display: flex; flex-direction: column; gap: 2px; }
  .cost-row .model-name { color: var(--text-dim); font-size: 10px; }
  .cost-row .model-cost { color: var(--text); font-weight: 700; }

  /* GRAPH NODES */
  .node circle { stroke-width: 2; transition: r 0.3s; }
  .node.active circle { stroke: var(--green); fill: #0d2818; }
  .node.idle circle { stroke: var(--gray); fill: #111; }
  .node.completed circle { stroke: #4b5563; fill: #0a0a0b; }
  .node.error circle { stroke: var(--red); fill: #1a0a0a; }
  .node.working circle { stroke: var(--green); fill: #0d2818; }
  .node.virtual circle { stroke: var(--copper); fill: #120d06; stroke-dasharray: 4,3; }

  .node text { font-family: 'JetBrains Mono', monospace; fill: var(--text); font-size: 10px; }
  .node text.model-text { fill: var(--text-dim); font-size: 9px; }
  .node text.cost-text { fill: var(--copper); font-size: 9px; }

  .link { fill: none; stroke: var(--border); stroke-width: 1.5; }
  .link.virtual-link { stroke: var(--copper-dim); stroke-dasharray: 4,3; stroke-opacity: 0.5; }

  @keyframes glow {
    0%, 100% { filter: drop-shadow(0 0 4px #22c55e88); }
    50% { filter: drop-shadow(0 0 12px #22c55ecc); }
  }
  .node.active, .node.working { animation: glow 2s ease-in-out infinite; }

  @keyframes pulse-ring {
    0% { r: 12; opacity: 0.8; }
    100% { r: 22; opacity: 0; }
  }
  .pulse-ring { animation: pulse-ring 1.5s ease-out infinite; }

  /* ===================== MOBILE LAYOUT ===================== */
  @media (max-width: 768px) {
    html, body { overflow: auto; }

    /* Hide desktop elements */
    #agent-toolbar, #main { display: none !important; }
    #header { height: 44px; padding: 0 14px; }
    #header .meta { gap: 14px; font-size: 10px; }
    #header .meta > div:nth-child(1) { display: none; } /* hide clock on mobile */

    /* Show mobile elements */
    #mobile-layout { display: flex; }
  }

  /* Mobile layout container — hidden by default (desktop) */
  #mobile-layout {
    display: none;
    flex-direction: column;
    background: var(--bg);
    min-height: calc(100vh - 44px);
    padding-bottom: 60px; /* space for bottom bar */
  }

  /* Cost summary strip */
  #m-cost-strip {
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 10px 12px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    flex-wrap: wrap;
    gap: 6px;
  }
  .m-cost-item { display: flex; flex-direction: column; align-items: center; gap: 2px; }
  .m-cost-label { color: var(--text-dim); font-size: 9px; letter-spacing: 1px; text-transform: uppercase; }
  .m-cost-val { color: var(--copper); font-weight: 700; font-size: 13px; }
  .m-cost-val.neutral { color: var(--text); }

  /* Agent cards section */
  #m-agents-section {
    padding: 10px 12px 4px;
  }
  .m-section-title {
    font-size: 9px; letter-spacing: 2px; color: var(--copper);
    text-transform: uppercase; margin-bottom: 8px;
  }
  .m-agent-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 6px;
    margin-bottom: 8px;
    overflow: hidden;
  }
  .m-agent-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px;
    cursor: pointer;
    user-select: none;
  }
  .m-agent-card-header:active { background: #1a1208; }
  .m-agent-name { font-size: 13px; font-weight: 700; color: var(--text); }
  .m-agent-meta { font-size: 10px; color: var(--text-dim); margin-top: 2px; }
  .m-agent-cost { color: var(--copper); font-weight: 700; font-size: 12px; }
  .m-agent-arrow {
    color: var(--copper); font-size: 14px;
    transition: transform 0.2s;
    flex-shrink: 0; margin-left: 8px;
  }
  .m-agent-card.expanded .m-agent-arrow { transform: rotate(180deg); }
  .m-agent-sessions {
    display: none;
    border-top: 1px solid var(--border);
    padding: 4px 0;
  }
  .m-agent-card.expanded .m-agent-sessions { display: block; }
  .m-session-row {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 14px;
    border-bottom: 1px solid #1a1a20;
    font-size: 10px;
  }
  .m-session-row:last-child { border-bottom: none; }
  .m-status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .m-status-dot.working { background: var(--green); }
  .m-status-dot.active { background: var(--green); }
  .m-status-dot.idle, .m-status-dot.completed, .m-status-dot.error { background: var(--gray); }
  .m-session-label { color: var(--text); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .m-session-model { color: var(--text-dim); font-size: 9px; }
  .m-session-cost { color: var(--copper); font-size: 10px; }

  /* Live feed mobile */
  #m-feed-section { padding: 10px 12px 4px; }
  #m-feed-list { background: var(--bg2); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
  .m-feed-item {
    padding: 7px 12px;
    font-size: 10px;
    border-bottom: 1px solid var(--border);
    display: flex; gap: 6px; align-items: baseline;
  }
  .m-feed-item:last-child { border-bottom: none; }

  /* Bottom bar */
  #m-bottom-bar {
    display: none;
    position: fixed;
    bottom: 0; left: 0; right: 0;
    height: 52px;
    background: var(--bg2);
    border-top: 1px solid var(--border);
    align-items: center;
    justify-content: space-around;
    padding: 0 16px;
    z-index: 200;
  }
  @media (max-width: 768px) {
    #m-bottom-bar { display: flex; }
  }
  .m-bar-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 8px 18px;
    border: 1px solid var(--border);
    background: var(--bg3);
    color: var(--text-dim);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .m-bar-btn:active { background: #1a1208; border-color: var(--copper); color: var(--copper); }
  .m-bar-btn.cron-on { border-color: var(--copper); color: var(--copper); background: #1a1208; }
  .m-bar-btn.graph-btn { color: var(--text); border-color: #333; }

  /* Graph fullscreen overlay */
  #m-graph-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: var(--bg);
    z-index: 500;
    flex-direction: column;
  }
  #m-graph-overlay.open { display: flex; }
  #m-graph-overlay-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--bg2);
    height: 44px;
    flex-shrink: 0;
  }
  #m-graph-overlay-header span { font-size: 11px; color: var(--copper); letter-spacing: 2px; }
  #m-graph-close {
    background: none; border: none; color: var(--text-dim);
    font-size: 20px; cursor: pointer; padding: 0 4px;
  }
  #m-graph-svg-container { flex: 1; overflow: hidden; }
</style>
</head>
<body>

<div id="header">
  <div class="logo">
    <span class="eye">👁️</span>
    <span class="title">OLYMPUS</span>
  </div>
  <div class="meta">
    <div><span class="val" id="clock">—</span></div>
    <div>SESSIONS <span class="val" id="hdr-sessions">—</span></div>
    <div>TODAY <span class="cost-val" id="hdr-cost">$—</span></div>
    <div>ALL TIME <span class="val" id="hdr-alltime">$—</span></div>
    <div style="color:#4b5563;font-size:10px" id="refresh-indicator">⟳</div>
  </div>
</div>

<div id="agent-toolbar">
  <span class="agent-filter-label">AGENT:</span>
</div>

<div id="main">
  <div id="graph-panel">
    <div class="panel-title">AGENT GRAPH — live</div>
    <svg id="graph-svg"></svg>
    <div id="task-panel">
      <span class="tp-close" onclick="document.getElementById('task-panel').style.display='none'">✕</span>
      <div class="tp-label" id="tp-label"></div>
      <div class="tp-text" id="tp-text"></div>
    </div>
  </div>

  <div id="right-panel">
    <div id="feed-panel">
      <div class="panel-title">LIVE FEED</div>
      <div id="feed-list"></div>
    </div>
    <div id="cost-panel">
      <div class="panel-title">COST BREAKDOWN — today</div>
      <div id="cost-rows"></div>
    </div>
  </div>
</div>

<!-- MOBILE LAYOUT -->
<div id="mobile-layout">
  <!-- Cost strip -->
  <div id="m-cost-strip">
    <div class="m-cost-item">
      <span class="m-cost-label">Today</span>
      <span class="m-cost-val" id="m-today-cost">$—</span>
    </div>
    <div class="m-cost-item">
      <span class="m-cost-label">Total</span>
      <span class="m-cost-val" id="m-total-cost">$—</span>
    </div>
    <div class="m-cost-item">
      <span class="m-cost-label">Agents</span>
      <span class="m-cost-val neutral" id="m-agents-count">—</span>
    </div>
    <div class="m-cost-item">
      <span class="m-cost-label">Sessions</span>
      <span class="m-cost-val neutral" id="m-sessions-count">—</span>
    </div>
  </div>

  <!-- Agent cards -->
  <div id="m-agents-section">
    <div class="m-section-title">Agents</div>
    <div id="m-agent-cards"></div>
  </div>

  <!-- Live feed -->
  <div id="m-feed-section">
    <div class="m-section-title">Live Feed</div>
    <div id="m-feed-list"></div>
  </div>
</div>

<!-- Mobile bottom bar -->
<div id="m-bottom-bar">
  <button class="m-bar-btn" id="m-cron-toggle" onclick="toggleMobileCron()">⏱ cron: OFF</button>
  <button class="m-bar-btn graph-btn" onclick="openGraphFullscreen()">📊 Grafo</button>
</div>

<!-- Graph fullscreen overlay -->
<div id="m-graph-overlay">
  <div id="m-graph-overlay-header">
    <span>AGENT GRAPH — live</span>
    <button id="m-graph-close" onclick="closeGraphFullscreen()">✕</button>
  </div>
  <div id="m-graph-svg-container">
    <!-- SVG will be rendered here on demand -->
  </div>
</div>

<div id="tooltip">
  <div class="tt-id" id="tt-id"></div>
  <div class="tt-row">model: <span id="tt-model">—</span></div>
  <div class="tt-row">cost: <span id="tt-cost">—</span></div>
  <div class="tt-row">status: <span id="tt-status">—</span></div>
  <div class="tt-row" id="tt-task-row" style="max-width:260px;word-break:break-word;display:none">task: <span id="tt-task" style="color:var(--text);font-style:italic">—</span></div>
</div>

<script>
const API_HEADERS = { 'Authorization': 'Bearer olympus2026' };
let sessionsData = [];
let costsData = {};
let agentsList = [];
let activeAgentFilter = 'ALL';
let showCron = false;
let showHistory = false;
let showActiveOnly = true;
let nodePositions = new Map(); // session_id → {x, y} — preserva posizioni tra refresh
let _graphInitialized = false; // true dopo il primo caricamento — skippa fitToContent

function isActive(session) {
  const fiveMinAgo = Date.now() - (5 * 60 * 1000);
  // updated_at potrebbe essere in secondi o millisecondi UNIX
  let updatedMs = session.updated_at;
  if (updatedMs && updatedMs < 1e12) updatedMs = updatedMs * 1000; // converti secondi → ms
  return session.status === 'working' || (updatedMs && updatedMs > fiveMinAgo);
}

function isHistoric(session) {
  const tenMinutesAgo = Date.now() - (10 * 60 * 1000);
  const isOld = session.updated_at && session.updated_at < tenMinutesAgo;
  const isDone = session.status === 'completed' || session.status === 'idle';
  return isOld && isDone && session.session_id.includes(':subagent:');
}

function isCron(sessionId) {
  return sessionId && sessionId.includes(':cron:');
}

// Clock
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent = now.toLocaleString('it-IT', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit', second: '2-digit'
  });
}
setInterval(updateClock, 1000);
updateClock();

function fmtCost(v) {
  if (!v) return '$0.0000';
  return '$' + (+v).toFixed(4);
}

function fmtTs(ts) {
  if (!ts) return '—';
  return new Date(ts * 1000).toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
}

function abbreviate(str, len=14) {
  if (!str) return '?';
  return str.length > len ? str.slice(0, len) + '…' : str;
}

// Extract agentId from session_id: "agent:website:main" → "website"
function extractAgentId(sessionId) {
  const parts = (sessionId || '').split(':');
  return parts[1] || 'unknown';
}

// Short label from session_id:
// "agent:website:subagent:14a06e1f-..." → "subagent:14a0"
// "agent:website:main" → "website:main"
// "agent:website:cron:xxx" → "cron:xxx(short)"
function virtualNodeLabel(agentId) {
  if (!agentId || agentId === '__root__') return '◈ Olympus';
  const id = agentId.replace(/^__agent__:?/, '').replace(/^__root__/, '');
  if (!id) return '◈ Olympus';
  return '◈ ' + id.charAt(0).toUpperCase() + id.slice(1);
}

function shortLabel(sessionId) {
  if (!sessionId || sessionId === '__root__') return 'Olympus';
  if (sessionId.startsWith('__agent__:')) return sessionId.replace('__agent__:', '');
  const parts = sessionId.split(':');
  // parts: ["agent","website","subagent","uuid"] or ["agent","website","main"]
  if (parts.length >= 4) {
    const type = parts[2];
    const tail = parts[3] ? parts[3].slice(0, 6) : '';
    return `${type}:${tail}`;
  } else if (parts.length === 3) {
    return `${parts[1]}:${parts[2]}`;
  }
  return abbreviate(sessionId, 16);
}

function extractNodeName(session) {
  if (session._virtual) return virtualNodeLabel(session.session_id);
  const id = session.session_id || '';
  const task = (session.task_preview || '').trim();

  // Pattern 1: 'Sei [il/la] Nome Cognome' — cattura fino a 4 parole significative
  // Es: 'Sei Argus' → 'Argus', 'Sei il Giudice UX/UI' → 'Giudice UX/UI'
  // Es: 'Sei Team Gamma' → 'Team Gamma', 'Sei Olympus Developer' → 'Olympus Developer'
  const seiMatch = task.match(/^Sei\s+(?:il\s+|la\s+|l['\'])?([A-Za-z][A-Za-zÀ-ÿ\/\-]{0,20}(?:\s+[A-Za-z][A-Za-zÀ-ÿ\/\-]{0,20}){0,2})/i);
  if (seiMatch) return seiMatch[1].trim();

  // Pattern 2: 'You are [Name]' (inglese)
  const youMatch = task.match(/^You are\s+(?:the\s+)?([A-Za-z][A-Za-z\s\/\-]{0,30})/i);
  if (youMatch) return youMatch[1].trim().split('\n')[0];

  // Pattern 3: cerca nomi noti ovunque nel task
  const knownAgents = ['Argus', 'Atlas', 'Hermes', 'Mercury', 'Forge', 'Olympus'];
  for (const agent of knownAgents) {
    if (task.includes(agent)) return agent;
  }

  // Pattern 3: session_id type
  if (id.includes(':main')) {
    const agent = id.split(':')[1] || 'Main';
    return agent.charAt(0).toUpperCase() + agent.slice(1);
  }
  if (id.includes(':cron:')) return '⏱ Cron';
  if (id.includes(':slash:')) return '/ Slash';
  if (id.includes(':telegram:')) return '💬 Telegram';
  if (id.includes(':subagent:')) {
    const agentPart = id.split(':')[1] || '';
    if (agentPart && agentPart !== 'website') return agentPart.charAt(0).toUpperCase() + agentPart.slice(1) + ' Agent';
    return 'Sub-' + id.split(':subagent:')[1].slice(0,4);
  }

  return id.slice(0, 10);
}

// --- AGENT FILTER TOOLBAR ---
function renderAgentToolbar(agents) {
  const toolbar = document.getElementById('agent-toolbar');
  // Keep label
  toolbar.innerHTML = '<span class="agent-filter-label">AGENT:</span>';

  // Cron toggle button
  const cronBtn = document.createElement('button');
  cronBtn.className = 'agent-btn' + (showCron ? ' active' : '');
  cronBtn.textContent = showCron ? '⏱ cron: ON' : '⏱ cron: OFF';
  cronBtn.style.marginLeft = 'auto';
  cronBtn.onclick = () => { showCron = !showCron; renderAgentToolbar(agentsList); renderGraph(sessionsData); };
  // will be appended after agent buttons

  // History toggle button
  const histBtn = document.createElement('button');
  histBtn.className = 'agent-btn' + (showHistory ? ' active' : '');
  histBtn.textContent = showHistory ? '📦 storici: ON' : '📦 storici: OFF';
  histBtn.style.marginLeft = '4px';
  histBtn.onclick = () => { showHistory = !showHistory; renderAgentToolbar(agentsList); renderGraph(sessionsData); };

  // Active only toggle button
  const activeBtn = document.createElement('button');
  activeBtn.className = 'agent-btn' + (showActiveOnly ? ' active' : '');
  activeBtn.textContent = showActiveOnly ? '⚡ attivi: ON' : '⚡ attivi: OFF';
  activeBtn.style.marginLeft = '4px';
  if (showActiveOnly) activeBtn.style.borderColor = '#22c55e';
  activeBtn.onclick = () => {
    showActiveOnly = !showActiveOnly;
    renderAgentToolbar(agentsList);
    renderGraph(sessionsData);
  };

  // Reset zoom button
  const resetBtn = document.createElement('button');
  resetBtn.className = 'agent-btn';
  resetBtn.textContent = '⊙ Reset zoom';
  resetBtn.style.marginLeft = '4px';
  resetBtn.onclick = () => { window._zoomReset && window._zoomReset(); };

  const allBtn = document.createElement('button');
  allBtn.className = 'agent-btn' + (activeAgentFilter === 'ALL' ? ' active' : '');
  allBtn.textContent = 'ALL';
  allBtn.onclick = () => { activeAgentFilter = 'ALL'; renderAgentToolbar(agentsList); renderGraph(sessionsData); };
  toolbar.appendChild(allBtn);

  agents.forEach(agentId => {
    const btn = document.createElement('button');
    btn.className = 'agent-btn' + (activeAgentFilter === agentId ? ' active' : '');
    btn.textContent = agentId;
    btn.onclick = () => { activeAgentFilter = agentId; renderAgentToolbar(agentsList); renderGraph(sessionsData); };
    toolbar.appendChild(btn);
  });

  toolbar.appendChild(cronBtn);
  toolbar.appendChild(histBtn);
  toolbar.appendChild(activeBtn);
  toolbar.appendChild(resetBtn);

  // Cost display
  let costDisplay = document.getElementById('cost-display');
  if (!costDisplay) {
    costDisplay = document.createElement('div');
    costDisplay.id = 'cost-display';
    costDisplay.style.cssText = 'margin-left:auto; color:#B87333; font-size:12px; font-family:JetBrains Mono,monospace; white-space:nowrap; padding:0 8px;';
    costDisplay.innerHTML = '~$<span id="cost-value">...</span> <span style="color:#555;font-size:10px;">stima mensile</span>';
    toolbar.appendChild(costDisplay);
  }
}

// --- GRAPH ---
function buildTreeWithVirtualRoots(sessions, filterAgent) {
  const byId = {};

  // Filter sessions if needed
  let visible = sessions;
  if (filterAgent && filterAgent !== 'ALL') {
    visible = sessions.filter(s => extractAgentId(s.session_id) === filterAgent);
  }
  // Filter cron if showCron is off
  if (!showCron) {
    visible = visible.filter(s => !isCron(s.session_id));
  }
  // Filter storici if showHistory is off
  if (!showHistory) {
    visible = visible.filter(s => !isHistoric(s));
  }
  // Filter attivi if showActiveOnly is on (virtual nodes are built after, not filtered here)
  if (showActiveOnly) {
    visible = visible.filter(s => isActive(s));
  }

  // Build map
  visible.forEach(s => { byId[s.session_id] = { ...s, children: [], _virtual: false }; });

  // Group by agentId for virtual root creation
  const agentGroups = {};
  visible.forEach(s => {
    const aid = extractAgentId(s.session_id);
    if (!agentGroups[aid]) agentGroups[aid] = [];
    agentGroups[aid].push(s.session_id);
  });

  // Create virtual agent roots
  const virtualRoots = [];
  Object.keys(agentGroups).forEach(aid => {
    const vId = `__agent__:${aid}`;
    byId[vId] = {
      session_id: vId,
      label: aid,
      model: '',
      cost_usd: 0,
      status: 'virtual',
      task_preview: `Agent: ${aid}`,
      children: [],
      _virtual: true
    };
    virtualRoots.push(vId);
  });

  // Wire up children
  visible.forEach(s => {
    if (s.parent_id && byId[s.parent_id]) {
      // Real parent exists in visible set
      byId[s.parent_id].children.push(byId[s.session_id]);
    } else {
      // No visible parent → attach to virtual agent root
      const aid = extractAgentId(s.session_id);
      const vId = `__agent__:${aid}`;
      if (byId[vId]) byId[vId].children.push(byId[s.session_id]);
    }
  });

  if (virtualRoots.length === 0) return null;
  if (virtualRoots.length === 1) return byId[virtualRoots[0]];
  return {
    session_id: '__root__',
    label: 'Olympus',
    model: '',
    cost_usd: 0,
    status: 'idle',
    children: virtualRoots.map(vid => byId[vid]),
    _virtual: true
  };
}

function calcDepth(sessionId, sessions, visited) {
  if (!visited) visited = new Set();
  if (visited.has(sessionId)) return 0;
  visited.add(sessionId);
  const session = sessions.find(s => s.session_id === sessionId);
  if (!session || !session.parent_id) return 0;
  return 1 + calcDepth(session.parent_id, sessions, visited);
}

function renderGraph(sessions) {
  if (!sessions || sessions.length === 0) return;
  const svg = d3.select('#graph-svg');
  svg.selectAll('*').remove();

  const el = document.getElementById('graph-svg');
  const W = el.clientWidth || 800;
  const H = el.clientHeight || 600;

  svg.attr('width', W).attr('height', H)
     .attr('viewBox', `0 0 ${W} ${H}`)
     .style('cursor', 'grab');

  const root_data = buildTreeWithVirtualRoots(sessions, activeAgentFilter);
  if (!root_data) return;

  // Build flat nodes + links for force simulation
  const allSessions = sessions.filter(s => showCron || !isCron(s.session_id));
  function flattenTree(node, nodesArr, linksArr) {
    nodesArr.push(node);
    (node.children || []).forEach(child => {
      linksArr.push({ source: node.session_id, target: child.session_id });
      flattenTree(child, nodesArr, linksArr);
    });
  }
  const flatNodes = [];
  const flatLinks = [];
  flattenTree(root_data, flatNodes, flatLinks);

  // Build depth map
  const depthMap = {};
  const sessionArr = flatNodes.filter(n => !n._virtual).map(n => ({ session_id: n.session_id, parent_id: n.parent_id }));
  flatNodes.forEach(n => {
    depthMap[n.session_id] = n._virtual ? 0 : 1 + calcDepth(n.session_id, sessionArr);
  });

  const graphGroup = svg.append('g').attr('transform', 'translate(0, 0)');

  // Setup zoom & pan
  const zoomBehavior = d3.zoom()
    .scaleExtent([0.1, 4])
    .on('zoom', (event) => {
      graphGroup.attr('transform', event.transform);
      window._savedZoomTransform = event.transform; // salva per il prossimo refresh
    });
  svg.call(zoomBehavior);
  // Ripristina zoom salvato tra refresh
  if (window._savedZoomTransform && _graphInitialized) {
    svg.call(zoomBehavior.transform, window._savedZoomTransform);
  }
  svg.on('dblclick.zoom', () => fitToContent && fitToContent());

  function fitToContent() {
    const bounds = graphGroup.node().getBBox();
    const padding = 60;
    if (bounds.width === 0 || bounds.height === 0) return;
    const scale = Math.min(
      (W - padding * 2) / bounds.width,
      (H - padding * 2) / bounds.height,
      1.5
    );
    const tx = (W - bounds.width * scale) / 2 - bounds.x * scale;
    const ty = (H - bounds.height * scale) / 2 - bounds.y * scale;
    svg.transition().duration(600).call(zoomBehavior.transform, d3.zoomIdentity.translate(tx, ty).scale(scale));
  }

  window._zoomReset = () => fitToContent();

  const nodeData = flatNodes.map(n => ({ ...n, x: W / 2 + (Math.random() - 0.5) * 100, y: 60 + (depthMap[n.session_id] || 0) * 120 }));
  // Ripristina posizioni salvate per nodi esistenti
  nodeData.forEach(d => {
    const saved = nodePositions.get(d.session_id);
    if (saved) { d.x = saved.x; d.y = saved.y; d.fx = null; d.fy = null; }
  });
  const nodeMap = {};
  nodeData.forEach(n => { nodeMap[n.session_id] = n; });

  // simLinks: same array used by BOTH forceLink AND linkSel so D3 mutates source/target in place
  const simLinks = flatLinks.map(l => ({
    source: l.source, target: l.target,
    _virtual_src: flatNodes.find(n => n.session_id === l.source)?._virtual,
    _virtual_tgt: flatNodes.find(n => n.session_id === l.target)?._virtual
  }));

  const linkGroup = graphGroup.append('g').attr('class', 'links');
  const nodeGroup = graphGroup.append('g').attr('class', 'nodes');

  const linkSel = linkGroup.selectAll('.link')
    .data(simLinks)
    .enter().append('line')
    .attr('class', d => 'link' + (d._virtual_src || d._virtual_tgt ? ' virtual-link' : ''))
    .attr('stroke', '#444')
    .attr('stroke-width', 1.5)
    .attr('opacity', 0);
  linkSel.transition().duration(500).attr('opacity', 1);

  const simulation = d3.forceSimulation(nodeData)
    .alphaDecay(0.03)
    .velocityDecay(0.5)
    .alphaMin(0.001)
    .force('link', d3.forceLink(simLinks).id(d => d.session_id).distance(220).strength(0.3))
    .force('charge', d3.forceManyBody().strength(-1200))
    .force('center', d3.forceCenter(W / 2, H / 2))
    .force('y', d3.forceY(d => 80 + (depthMap[d.session_id] || 0) * 120).strength(0.15))
    .force('collision', d3.forceCollide(70));

  // Nodes
  const node = nodeGroup.selectAll('.node')
    .data(nodeData)
    .enter().append('g')
    .attr('class', d => `node ${d._virtual ? 'virtual' : (d.status || 'idle')}`)
    .attr('transform', d => `translate(${d.x},${d.y})`)
    .style('cursor', 'pointer')
    .style('opacity', 0)
    .on('click', (event, d) => {
      if (!d._virtual) {
        if (window.innerWidth <= 768) {
          openMobileSheet(d);
        } else {
          openDrawer(d);
        }
      }
    })
    .on('mousemove', (event, d) => {
      const tt = document.getElementById('tooltip');
      document.getElementById('tt-id').textContent = d.session_id;
      document.getElementById('tt-model').textContent = d.model || '—';
      document.getElementById('tt-cost').textContent = fmtCost(d.cost_usd);
      document.getElementById('tt-status').textContent = d.status || '—';
      const ttTask = document.getElementById('tt-task');
      const ttTaskRow = document.getElementById('tt-task-row');
      if (d.task_preview) {
        ttTask.textContent = d.task_preview.substring(0, 120);
        ttTaskRow.style.display = '';
      } else {
        ttTaskRow.style.display = 'none';
      }
      tt.style.display = 'block';
      tt.style.left = (event.clientX + 14) + 'px';
      tt.style.top = (event.clientY - 10) + 'px';
    })
    .on('mouseleave', () => {
      document.getElementById('tooltip').style.display = 'none';
    });

  // Pulse ring for active/working nodes
  node.filter(d => d.status === 'active' || d.status === 'working')
    .append('circle')
    .attr('class', 'pulse-ring')
    .attr('r', 12)
    .attr('fill', 'none')
    .attr('stroke', '#22c55e')
    .attr('stroke-width', 1.5)
    .attr('opacity', 0.6);

  node.append('circle')
    .attr('r', d => d._virtual ? 13 : 10);

  // Short label above node
  node.append('text')
    .attr('dy', -18)
    .attr('text-anchor', 'middle')
    .style('font-weight', d => d._virtual ? '700' : '400')
    .style('fill', d => d._virtual ? 'var(--copper)' : 'var(--text)')
    .text(d => extractNodeName(d));

  // Task preview secondary label (below short label, above node)
  node.filter(d => !d._virtual && d.task_preview)
    .append('text')
    .attr('dy', -7)
    .attr('text-anchor', 'middle')
    .style('font-size', '8px')
    .style('fill', '#888')
    .text(d => d.task_preview ? d.task_preview.substring(0, 30) : '');

  // Model below node (not for virtual)
  node.filter(d => !d._virtual)
    .append('text')
    .attr('class', 'model-text')
    .attr('dy', 24)
    .attr('text-anchor', 'middle')
    .text(d => d.model ? abbreviate(d.model, 18) : '');

  // Cost below model
  node.filter(d => !d._virtual && d.cost_usd)
    .append('text')
    .attr('class', 'cost-text')
    .attr('dy', 36)
    .attr('text-anchor', 'middle')
    .text(d => fmtCost(d.cost_usd));

  // Wire up tick: update link and node positions live
  simulation.on('tick', () => {
    linkSel
      .attr('x1', d => d.source.x || 0)
      .attr('y1', d => d.source.y || 0)
      .attr('x2', d => d.target.x || 0)
      .attr('y2', d => d.target.y || 0);
    node.attr('transform', d => `translate(${d.x},${d.y})`);
  });

  simulation.on('end', () => {
    // Fade-in nodes after layout stabilizes
    node.transition().duration(500).style('opacity', 1);
    // fitToContent solo al primo caricamento — evita reset zoom ad ogni refresh
    if (!_graphInitialized) {
      fitToContent();
      _graphInitialized = true;
    }
    simulation.stop();
    // Salva posizioni per il prossimo refresh
    simulation.nodes().forEach(d => {
      if (d.session_id) nodePositions.set(d.session_id, { x: d.x, y: d.y });
    });
  });
  simulation.restart();
}

// --- FEED ---
function renderFeed(events) {
  const list = document.getElementById('feed-list');
  list.innerHTML = '';
  events.slice(0, 20).forEach(ev => {
    const div = document.createElement('div');
    div.className = 'feed-item';
    const typeClass = ['spawn','complete','error','tool_call'].includes(ev.type) ? ev.type : '';
    div.innerHTML = `<span class="fi-ts">${fmtTs(ev.ts)}</span><span class="fi-type ${typeClass}">${ev.type}</span><span class="fi-label">${shortLabel(ev.session_id)}</span>`;
    list.appendChild(div);
  });
}

// --- COSTS ---
function renderCosts(costs) {
  document.getElementById('hdr-cost').textContent = fmtCost(costs.today);
  document.getElementById('hdr-alltime').textContent = fmtCost(costs.allTime);
  const rows = document.getElementById('cost-rows');
  rows.innerHTML = '';
  (costs.byModel || []).forEach(m => {
    const div = document.createElement('div');
    div.className = 'cost-row';
    div.innerHTML = `<span class="model-name">${abbreviate(m.model || 'unknown', 30)}</span><span class="model-cost">${fmtCost(m.cost)}</span>`;
    rows.appendChild(div);
  });
}

// --- POLL ---
async function refresh() {
  const ind = document.getElementById('refresh-indicator');
  ind.style.color = '#B87333';
  try {
    const [sRes, cRes, eRes, aRes] = await Promise.all([
      fetch('/api/sessions', { headers: API_HEADERS }),
      fetch('/api/costs', { headers: API_HEADERS }),
      fetch('/api/events?limit=50', { headers: API_HEADERS }),
      fetch('/api/agents', { headers: API_HEADERS }),
    ]);
    const sessions = await sRes.json();
    const costs = await cRes.json();
    const events = await eRes.json();
    const agents = await aRes.json();

    sessionsData = sessions;
    costsData = costs;
    agentsList = agents;

    document.getElementById('hdr-sessions').textContent = sessions.length;
    renderAgentToolbar(agents);
    renderGraph(sessions);
    renderCosts(costs);
    renderFeed(events);

    // Update monthly cost display
    fetch('/api/stats', { headers: API_HEADERS })
      .then(r => r.json())
      .then(data => {
        const el = document.getElementById('cost-value');
        if (el) el.textContent = (data.total?.total || 0).toFixed(4);
      })
      .catch(() => {});

    ind.style.color = '#22c55e';
  } catch (e) {
    ind.style.color = '#ef4444';
    console.error('Refresh error:', e);
  }
  setTimeout(() => { ind.style.color = '#4b5563'; }, 2000);
}

// ===================== MOBILE JS =====================

function isMobile() {
  return window.innerWidth <= 768;
}

// Mobile cron toggle
function toggleMobileCron() {
  showCron = !showCron;
  const btn = document.getElementById('m-cron-toggle');
  btn.textContent = showCron ? '⏱ cron: ON' : '⏱ cron: OFF';
  btn.classList.toggle('cron-on', showCron);
  renderMobile();
  // Also sync desktop toolbar
  renderAgentToolbar(agentsList);
  renderGraph(sessionsData);
}

// Toggle agent card expand/collapse
function toggleAgentCard(agentId) {
  const card = document.querySelector(`.m-agent-card[data-agent="${CSS.escape(agentId)}"]`);
  if (card) card.classList.toggle('expanded');
}

// Open D3 graph fullscreen overlay
let mGraphRendered = false;
function openGraphFullscreen() {
  const overlay = document.getElementById('m-graph-overlay');
  overlay.classList.add('open');
  if (!mGraphRendered) {
    renderMobileGraph();
    mGraphRendered = true;
  }
}
function closeGraphFullscreen() {
  document.getElementById('m-graph-overlay').classList.remove('open');
}

function renderMobileGraph() {
  const container = document.getElementById('m-graph-svg-container');
  container.innerHTML = '';
  const svg = d3.select('#m-graph-svg-container').append('svg')
    .attr('width', '100%')
    .attr('height', '100%')
    .style('width', '100%')
    .style('height', '100%');

  const W = container.clientWidth || window.innerWidth;
  const H = container.clientHeight || (window.innerHeight - 44);

  const root_data = buildTreeWithVirtualRoots(sessionsData, activeAgentFilter);
  if (!root_data) return;

  const root = d3.hierarchy(root_data);
  const treeLayout = d3.tree().size([W - 60, H - 100]);
  treeLayout(root);

  const g = svg.append('g').attr('transform', 'translate(30, 60)');

  g.selectAll('.link')
    .data(root.links()).enter().append('path')
    .attr('class', d => 'link' + ((d.source.data._virtual || d.target.data._virtual) ? ' virtual-link' : ''))
    .attr('d', d3.linkVertical().x(d => d.x).y(d => d.y));

  const node = g.selectAll('.node').data(root.descendants()).enter().append('g')
    .attr('class', d => `node ${d.data._virtual ? 'virtual' : (d.data.status || 'idle')}`)
    .attr('transform', d => `translate(${d.x},${d.y})`);

  node.append('circle').attr('r', d => d.data._virtual ? 13 : 10);

  node.append('text').attr('dy', -18).attr('text-anchor', 'middle')
    .style('font-weight', d => d.data._virtual ? '700' : '400')
    .style('fill', d => d.data._virtual ? 'var(--copper)' : 'var(--text)')
    .text(d => extractNodeName(d.data));

  node.filter(d => !d.data._virtual && d.data.task_preview)
    .append('text').attr('dy', -7).attr('text-anchor', 'middle')
    .style('font-size', '8px').style('fill', '#888')
    .text(d => d.data.task_preview ? d.data.task_preview.substring(0, 30) : '');
}

// Main mobile render
function renderMobile() {
  // NOTE: guard rimosso — il CSS (media query) gestisce la visibilità del layout mobile.
  // JS deve SEMPRE popolare il DOM così le card sono pronte quando l'utente è su mobile.

  // Cost strip
  const _costs = costsData || {};
  document.getElementById('m-today-cost').textContent = fmtCost(_costs.today);
  document.getElementById('m-total-cost').textContent = fmtCost(_costs.allTime);
  document.getElementById('m-agents-count').textContent = (agentsList || []).length;
  document.getElementById('m-sessions-count').textContent = (sessionsData || []).length;

  // Build agent → sessions map
  const agentMap = {};
  let visible = sessionsData || [];
  if (!showCron) visible = visible.filter(s => !isCron(s.session_id));

  visible.forEach(s => {
    const aid = extractAgentId(s.session_id);
    if (!agentMap[aid]) agentMap[aid] = { sessions: [], cost: 0, active: 0 };
    agentMap[aid].sessions.push(s);
    agentMap[aid].cost += +(s.cost_usd || 0);
    if (s.status === 'working' || s.status === 'active') agentMap[aid].active++;
  });

  // Render agent cards
  const cardsEl = document.getElementById('m-agent-cards');
  // Preserve expanded state
  const expanded = new Set();
  cardsEl.querySelectorAll('.m-agent-card.expanded').forEach(c => expanded.add(c.dataset.agent));
  cardsEl.innerHTML = '';

  Object.entries(agentMap).forEach(([aid, info]) => {
    const card = document.createElement('div');
    card.className = 'm-agent-card' + (expanded.has(aid) ? ' expanded' : '');
    card.dataset.agent = aid;

    const sessCount = info.sessions.length;
    const activeTxt = info.active > 0 ? ` · ${info.active} active` : '';

    card.innerHTML = `
      <div class="m-agent-card-header" onclick="toggleAgentCard('${aid.replace(/'/g,"\\'")}')">
        <div>
          <div class="m-agent-name">${aid}</div>
          <div class="m-agent-meta">${sessCount} sessions${activeTxt}</div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <span class="m-agent-cost">${fmtCost(info.cost)}</span>
          <span class="m-agent-arrow">▼</span>
        </div>
      </div>
      <div class="m-agent-sessions">
        ${info.sessions.map(s => {
          const dotClass = (s.status === 'working' || s.status === 'active') ? 'working' : 'idle';
          return `<div class="m-session-row">
            <div class="m-status-dot ${dotClass}"></div>
            <div class="m-session-label">${extractNodeName(s)}</div>
            <div class="m-session-model">${abbreviate(s.model || '', 16)}</div>
            <div class="m-session-cost">${fmtCost(s.cost_usd)}</div>
          </div>`;
        }).join('')}
      </div>
    `;
    cardsEl.appendChild(card);
  });

  // Render feed
  const feedEl = document.getElementById('m-feed-list');
  feedEl.innerHTML = '';
  (window._lastEvents || []).slice(0, 20).forEach(ev => {
    const div = document.createElement('div');
    div.className = 'm-feed-item feed-item';
    const typeClass = ['spawn','complete','error','tool_call'].includes(ev.type) ? ev.type : '';
    div.innerHTML = `<span class="fi-ts">${fmtTs(ev.ts)}</span><span class="fi-type ${typeClass}">${ev.type}</span><span class="fi-label">${shortLabel(ev.session_id)}</span>`;
    feedEl.appendChild(div);
  });

  // Reset graph (will re-render on next open)
  mGraphRendered = false;
}

// Hook into refresh to also run mobile render
const _origRefresh = refresh;
async function refreshWithMobile() {
  // We need to capture events for mobile feed
  const ind = document.getElementById('refresh-indicator');
  ind.style.color = '#B87333';
  try {
    const [sRes, cRes, eRes, aRes] = await Promise.all([
      fetch('/api/sessions', { headers: API_HEADERS }),
      fetch('/api/costs', { headers: API_HEADERS }),
      fetch('/api/events?limit=50', { headers: API_HEADERS }),
      fetch('/api/agents', { headers: API_HEADERS }),
    ]);
    const sessions = await sRes.json();
    const costs = await cRes.json();
    const events = await eRes.json();
    const agents = await aRes.json();

    sessionsData = sessions;
    costsData = costs;
    agentsList = agents;
    window._lastEvents = events;

    document.getElementById('hdr-sessions').textContent = sessions.length;
    renderAgentToolbar(agents);
    renderGraph(sessions);
    renderCosts(costs);
    renderFeed(events);
    renderMobile();
    ind.style.color = '#22c55e';
  } catch (e) {
    ind.style.color = '#ef4444';
    console.error('Refresh error:', e);
  }
  setTimeout(() => { ind.style.color = '#4b5563'; }, 2000);
}

// Mobile auto-refresh every 15s (in addition to desktop 10s)
// We replace the global refresh call with the unified one
refreshWithMobile().then(() => {
  // On mobile, show graph overlay by default after first load
  if (isMobile()) {
    openGraphFullscreen();
  }
});
setInterval(refreshWithMobile, 10000);
</script>
<div id="node-drawer" style="display:none; position:fixed; top:48px; left:0; width:320px; height:calc(100vh - 48px); background:#111114; border-right:1px solid #222228; z-index:100; overflow-y:auto; padding:20px; font-family:'JetBrains Mono',monospace;">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
    <span id="drawer-title" style="color:#B87333; font-size:14px; font-weight:700;"></span>
    <button onclick="closeDrawer()" style="background:none; border:none; color:#888; font-size:18px; cursor:pointer;">✕</button>
  </div>
  <div id="drawer-content"></div>
</div>

<script>
function openDrawer(session) {
  const name = extractNodeName(session);
  document.getElementById('drawer-title').textContent = name;
  const cost = session.cost_usd ? `$${session.cost_usd.toFixed(4)}` : '$0.0000';
  const tokIn = session.tokens_in || 0;
  const tokOut = session.tokens_out || 0;
  const trelloLink = session.trello_card_url
    ? `<a href="${session.trello_card_url}" target="_blank" style="color:#B87333;">🔗 Trello card</a>`
    : '<span style="color:#555;">Nessuna card Trello</span>';
  const status = session.status || 'unknown';
  const statusColor = status === 'working' ? '#22c55e' : '#4b5563';
  const task = session.task_preview || 'N/A';

  document.getElementById('drawer-content').innerHTML = `
    <div style="margin-bottom:12px;">
      <div style="color:#555; font-size:10px; margin-bottom:4px;">STATUS</div>
      <div style="color:${statusColor}; font-size:12px;">● ${status}</div>
    </div>
    <div style="margin-bottom:12px;">
      <div style="color:#555; font-size:10px; margin-bottom:4px;">MODEL</div>
      <div style="color:#E8E8E8; font-size:11px;">${session.model || 'unknown'}</div>
    </div>
    <div style="margin-bottom:12px;">
      <div style="color:#555; font-size:10px; margin-bottom:4px;">TOKENS</div>
      <div style="color:#E8E8E8; font-size:11px;">in: ${tokIn.toLocaleString()} / out: ${tokOut.toLocaleString()}</div>
    </div>
    <div style="margin-bottom:12px;">
      <div style="color:#555; font-size:10px; margin-bottom:4px;">COSTO</div>
      <div style="color:#B87333; font-size:13px; font-weight:700;">${cost}</div>
    </div>
    <div style="margin-bottom:12px;">
      <div style="color:#555; font-size:10px; margin-bottom:4px;">TRELLO</div>
      ${trelloLink}
    </div>
    <div style="margin-bottom:12px;">
      <div style="color:#555; font-size:10px; margin-bottom:4px;">SESSION ID</div>
      <div style="color:#555; font-size:9px; word-break:break-all;">${session.session_id}</div>
    </div>
    <div>
      <div style="color:#555; font-size:10px; margin-bottom:4px;">TASK</div>
      <div style="color:#888; font-size:10px; line-height:1.5; max-height:200px; overflow-y:auto; white-space:pre-wrap;">${task}</div>
    </div>
  `;
  const drawer = document.getElementById('node-drawer');
  drawer.style.display = 'block';
  if (window.innerWidth <= 768) {
    drawer.style.width = '100vw';
  } else {
    drawer.style.width = '320px';
  }
}

function closeDrawer() {
  document.getElementById('node-drawer').style.display = 'none';
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeDrawer(); closeMobileSheet(); } });

function openMobileSheet(session) {
  const title = document.getElementById('sheet-title');
  const content = document.getElementById('sheet-content');
  if (!title || !content) return;
  title.textContent = extractNodeName ? extractNodeName(session) : (session.session_id || '');
  const statusColor = session.status === 'working' ? '#22c55e' : session.status === 'error' ? '#ef4444' : '#888';
  const trelloLink = session.trello_card_url ? `<div style="margin-top:12px"><a href="${session.trello_card_url}" target="_blank" style="color:#B87333;font-size:11px;">🔗 Trello card</a></div>` : '';
  content.innerHTML = `
    <div style="font-size:11px; color:#888; margin-bottom:8px;">${session.session_id}</div>
    <div style="display:flex; gap:16px; margin-bottom:12px; font-size:12px;">
      <span>Status: <span style="color:${statusColor}">${session.status || '—'}</span></span>
      <span>Model: <span style="color:#E8E8E8">${session.model || '—'}</span></span>
    </div>
    <div style="font-size:12px; margin-bottom:8px;">Tokens in: <span style="color:#E8E8E8">${(session.tokens_in||0).toLocaleString()}</span> &nbsp; out: <span style="color:#E8E8E8">${(session.tokens_out||0).toLocaleString()}</span></div>
    <div style="font-size:13px; color:#B87333; margin-bottom:12px;">Cost: $${(session.cost_usd||0).toFixed(4)}</div>
    ${session.task_preview ? `<div style="font-size:11px; color:#888; line-height:1.5; background:#0A0A0B; padding:10px; border-radius:6px; word-break:break-word;">${session.task_preview}</div>` : ''}
    ${trelloLink}
  `;
  document.getElementById('mobile-sheet').style.display = 'block';
}

function closeMobileSheet() {
  const el = document.getElementById('mobile-sheet');
  if (el) el.style.display = 'none';
}
</script>

<div id="mobile-sheet" style="display:none; position:fixed; bottom:0; left:0; right:0; height:60vh; background:#111114; border-top:2px solid #B87333; border-radius:16px 16px 0 0; z-index:200; overflow-y:auto; padding:20px; font-family:'JetBrains Mono',monospace; transition:transform 0.3s ease;">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
    <span id="sheet-title" style="color:#B87333; font-size:14px; font-weight:700;"></span>
    <button onclick="closeMobileSheet()" style="background:none; border:none; color:#888; font-size:18px; cursor:pointer;">✕</button>
  </div>
  <div id="sheet-content"></div>
</div>

</body>
</html>
