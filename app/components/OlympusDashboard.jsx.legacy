'use client';

import { useEffect } from 'react';

const DASHBOARD_HTML = "<div id=\"header\">\n  <div class=\"logo\">\n    <span class=\"eye\"><svg class=\"eye-svg\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#E8E8E8\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg></span>\n    <span class=\"title\">OLYMPUS</span>\n  </div>\n  <div class=\"meta\">\n    <div><span class=\"val\" id=\"clock\">—</span></div>\n    <div>SESSIONS <span class=\"val\" id=\"hdr-sessions\">—</span></div>\n    <div>TODAY <span class=\"cost-val\" id=\"hdr-cost\">$—</span></div>\n    <div>ALL TIME <span class=\"val\" id=\"hdr-alltime\">$—</span></div>\n    <div style=\"color:#4b5563;font-size:10px\" id=\"refresh-indicator\">⟳</div>\n    <button id=\"screenshot-btn\" onclick=\"downloadScreenshot()\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z\"/><circle cx=\"12\" cy=\"13\" r=\"4\"/></svg></button>\n  </div>\n</div>\n\n<div id=\"agent-toolbar\">\n  <span class=\"agent-filter-label\">AGENT:</span>\n</div>\n\n<div id=\"main\">\n  <div id=\"graph-panel\">\n    <div class=\"panel-title\">AGENT GRAPH — live</div>\n    <svg id=\"graph-svg\"></svg>\n    <div id=\"task-panel\">\n      <span class=\"tp-close\" onclick=\"document.getElementById('task-panel').style.display='none'\">✕</span>\n      <div class=\"tp-label\" id=\"tp-label\"></div>\n      <div class=\"tp-text\" id=\"tp-text\"></div>\n    </div>\n  </div>\n\n  <div id=\"right-panel\">\n    <div id=\"feed-panel\">\n      <div class=\"panel-title\">LIVE FEED</div>\n      <div id=\"feed-list\"></div>\n    </div>\n    <div id=\"cost-panel\">\n      <div class=\"panel-title\">COST BREAKDOWN — today</div>\n      <div id=\"cost-rows\"></div>\n    </div>\n    <div id=\"tool-calls-panel\">\n      <div class=\"panel-title\">TOOL CALLS — last 50</div>\n      <div class=\"tc-scroll\">\n        <table>\n          <thead>\n            <tr>\n              <th>time</th>\n              <th>session</th>\n              <th>tool</th>\n              <th>status</th>\n              <th>ms</th>\n            </tr>\n          </thead>\n          <tbody id=\"tool-calls-tbody-desktop\"></tbody>\n        </table>\n        <div id=\"tool-calls-empty-desktop\" style=\"display:none; color:#444; padding:10px 0; font-family:'JetBrains Mono',monospace; font-size:10px;\">no tool calls recorded yet</div>\n      </div>\n    </div>\n    <div id=\"crons-panel\">\n      <div class=\"panel-title\">CRONS — status</div>\n      <div class=\"crons-scroll\">\n        <table>\n          <thead>\n            <tr>\n              <th>name</th>\n              <th>schedule</th>\n              <th>last run</th>\n              <th>status</th>\n              <th>dur</th>\n              <th>next</th>\n            </tr>\n          </thead>\n          <tbody id=\"crons-tbody-desktop\"></tbody>\n        </table>\n        <div id=\"crons-empty-desktop\" style=\"display:none; color:#444; padding:10px 0; font-family:'JetBrains Mono',monospace; font-size:10px;\">no crons found</div>\n      </div>\n    </div>\n\n    <!-- SYSTEM METRICS PANEL -->\n    <div id=\"system-panel\">\n      <div class=\"panel-title\">SYSTEM — <span id=\"sys-ts\" style=\"font-size:9px;color:#555;\">—</span></div>\n      <div id=\"system-content\">\n        <!-- CPU -->\n        <div class=\"sys-row\">\n          <div class=\"sys-label\">CPU <span id=\"sys-cpu-alert\" class=\"sys-alert\" style=\"display:none;\">⚠ ALERT</span></div>\n          <div class=\"sys-value\" id=\"sys-cpu-val\">—</div>\n          <div id=\"sys-sparkline\"></div>\n        </div>\n        <!-- RAM -->\n        <div class=\"sys-row\">\n          <div class=\"sys-label\">RAM <span id=\"sys-ram-alert\" class=\"sys-alert\" style=\"display:none;\">⚠ ALERT</span></div>\n          <div class=\"sys-value\" id=\"sys-ram-val\">—</div>\n          <div class=\"sys-bar-wrap\"><div class=\"sys-bar\" id=\"sys-ram-bar\"></div></div>\n          <div class=\"sys-sub\" id=\"sys-ram-sub\">—</div>\n        </div>\n        <!-- Disk -->\n        <div class=\"sys-row\">\n          <div class=\"sys-label\">DISK</div>\n          <div class=\"sys-value\" id=\"sys-disk-val\">—</div>\n          <div class=\"sys-bar-wrap\"><div class=\"sys-bar\" id=\"sys-disk-bar\"></div></div>\n          <div class=\"sys-sub\" id=\"sys-disk-sub\">—</div>\n        </div>\n        <!-- Load avg -->\n        <div class=\"sys-row\">\n          <div class=\"sys-label\">LOAD</div>\n          <div class=\"sys-value\" id=\"sys-load-val\">—</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- MOBILE LAYOUT — ALPHA: Command Center -->\n<div id=\"mobile-layout\">\n  <!-- Top toolbar: cost + active toggle -->\n  <div id=\"alpha-toolbar\">\n    <span id=\"alpha-cost\"><span id=\"alpha-cost-estimated-wrap\" style=\"display:none;\">~$<span id=\"alpha-cost-estimated\">...</span> <span style=\"color:#444;\">|</span> </span>$<span id=\"alpha-cost-real\">—</span> <button onclick=\"openCostOverride()\" style=\"background:none;border:1px solid #444;color:#888;font-size:9px;font-family:'JetBrains Mono',monospace;padding:1px 5px;border-radius:3px;cursor:pointer;\">✏️</button> <a href=\"https://github.com/settings/billing/summary\" target=\"_blank\" style=\"color:#555;font-size:9px;text-decoration:none;\">↗</a></span>\n    <button id=\"alpha-active-btn\" class=\"on\" onclick=\"alphaToggleActive()\"><svg width=\"11\" height=\"14\" viewBox=\"0 0 11 14\" fill=\"none\" style=\"vertical-align:middle;margin-right:3px;position:relative;top:-1px\"><path d=\"M6.5 1L1 8h4.5L4.5 13 10 6H5.5L6.5 1z\" fill=\"#E8E8E8\"/></svg> active only: ON</button>\n    <button id=\"screenshot-btn-mobile\" onclick=\"downloadScreenshot()\" style=\"font-family:'JetBrains Mono',monospace;font-size:11px;padding:5px 10px;border:1px solid var(--border);background:var(--bg3);color:var(--text-dim);border-radius:4px;cursor:pointer;display:flex;align-items:center;gap:5px;\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z\"/><circle cx=\"12\" cy=\"13\" r=\"4\"/></svg></button>\n  </div>\n\n  <!-- Tab content area -->\n  <div id=\"alpha-tab-content\">\n    <!-- Tab: Graph -->\n    <div class=\"alpha-tab-pane active\" id=\"alpha-tab-graph\">\n      <!-- D3 graph rendered inline, fullscreen -->\n      <svg id=\"alpha-graph-svg\" style=\"width:100%;height:100%;\"></svg>\n    </div>\n\n    <!-- Tab: Feed -->\n    <div class=\"alpha-tab-pane\" id=\"alpha-tab-feed\">\n      <div id=\"alpha-feed-list\"></div>\n    </div>\n\n    <!-- Tab: Tools -->\n    <div class=\"alpha-tab-pane\" id=\"alpha-tab-tools\">\n      <div style=\"padding: 16px 20px 8px 20px; color: #888; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em;\">TOOL CALLS — last 50</div>\n      <div style=\"overflow-x: auto; padding: 0 12px;\">\n        <table id=\"tool-calls-table\" style=\"width:100%; border-collapse: collapse; font-family: 'JetBrains Mono', monospace; font-size: 11px;\">\n          <thead>\n            <tr style=\"border-bottom: 1px solid #222; color: #555;\">\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">timestamp</th>\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">session</th>\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">tool</th>\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">status</th>\n              <th style=\"text-align:right; padding: 6px 10px; font-weight: 400;\">dur</th>\n              <th style=\"text-align:right; padding: 6px 10px; font-weight: 400;\">cost</th>\n            </tr>\n          </thead>\n          <tbody id=\"tool-calls-tbody\"></tbody>\n        </table>\n        <div id=\"tool-calls-empty\" style=\"display:none; color:#444; font-family:'JetBrains Mono',monospace; font-size:11px; padding:20px 10px;\">no tool calls recorded yet</div>\n      </div>\n    </div>\n\n    <!-- Tab: Crons -->\n    <div class=\"alpha-tab-pane\" id=\"alpha-tab-crons\">\n      <div style=\"padding: 16px 20px 8px 20px; color: #888; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em;\">CRONS — status</div>\n      <div style=\"overflow-x: auto; padding: 0 12px;\">\n        <table style=\"width:100%; border-collapse: collapse; font-family: 'JetBrains Mono', monospace; font-size: 11px;\">\n          <thead>\n            <tr style=\"border-bottom: 1px solid #222; color: #555;\">\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">name</th>\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">schedule</th>\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">last run</th>\n              <th style=\"text-align:left; padding: 6px 10px; font-weight: 400;\">status</th>\n              <th style=\"text-align:right; padding: 6px 10px; font-weight: 400;\">dur</th>\n              <th style=\"text-align:right; padding: 6px 10px; font-weight: 400;\">next</th>\n            </tr>\n          </thead>\n          <tbody id=\"crons-tbody\"></tbody>\n        </table>\n        <div id=\"crons-empty\" style=\"display:none; color:#444; font-family:'JetBrains Mono',monospace; font-size:11px; padding:20px 10px;\">no crons found</div>\n      </div>\n    </div>\n\n    <!-- Tab: Stats -->\n    <div class=\"alpha-tab-pane\" id=\"alpha-tab-stats\">\n      <div id=\"alpha-stats-content\">\n        <div class=\"alpha-stat-card\">\n          <div class=\"alpha-stat-card-title\">Total Sessions</div>\n          <div class=\"alpha-stat-big\" id=\"alpha-total-sessions\">—</div>\n          <div class=\"alpha-stat-sub\" id=\"alpha-active-count\">— active</div>\n        </div>\n        <div class=\"alpha-stat-card\">\n          <div class=\"alpha-stat-card-title\">Est. Monthly Cost</div>\n          <div class=\"alpha-stat-big\" style=\"color:var(--copper)\" id=\"alpha-monthly-cost\">$—</div>\n        </div>\n        <div class=\"alpha-stat-card\">\n          <div class=\"alpha-stat-card-title\">By Model</div>\n          <div id=\"alpha-model-breakdown\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n    <!-- Tab: System -->\n    <div class=\"alpha-tab-pane\" id=\"alpha-tab-system\">\n      <div style=\"padding: 16px 20px 8px 20px; color: #888; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em;\">SYSTEM — <span id=\"m-sys-ts\" style=\"font-size:9px;\"></span></div>\n      <div style=\"padding: 0 16px 16px; display:flex; flex-direction:column; gap:12px;\">\n        <!-- CPU -->\n        <div class=\"alpha-stat-card\">\n          <div class=\"alpha-stat-card-title\">CPU <span id=\"m-sys-cpu-alert\" class=\"sys-alert\" style=\"display:none;\">⚠ ALERT</span></div>\n          <div style=\"display:flex; align-items:baseline; gap:8px;\">\n            <span class=\"alpha-stat-big\" id=\"m-sys-cpu-val\">—</span>\n          </div>\n          <div id=\"m-sys-sparkline\" style=\"margin-top:8px;\"></div>\n        </div>\n        <!-- RAM -->\n        <div class=\"alpha-stat-card\">\n          <div class=\"alpha-stat-card-title\">RAM <span id=\"m-sys-ram-alert\" class=\"sys-alert\" style=\"display:none;\">⚠ ALERT</span></div>\n          <div style=\"display:flex; align-items:baseline; gap:8px;\">\n            <span class=\"alpha-stat-big\" id=\"m-sys-ram-val\">—</span>\n            <span class=\"alpha-stat-sub\" id=\"m-sys-ram-sub\">—</span>\n          </div>\n          <div class=\"sys-bar-wrap\" style=\"margin-top:8px;\"><div class=\"sys-bar\" id=\"m-sys-ram-bar\"></div></div>\n        </div>\n        <!-- Disk -->\n        <div class=\"alpha-stat-card\">\n          <div class=\"alpha-stat-card-title\">DISK</div>\n          <div style=\"display:flex; align-items:baseline; gap:8px;\">\n            <span class=\"alpha-stat-big\" id=\"m-sys-disk-val\">—</span>\n            <span class=\"alpha-stat-sub\" id=\"m-sys-disk-sub\">—</span>\n          </div>\n          <div class=\"sys-bar-wrap\" style=\"margin-top:8px;\"><div class=\"sys-bar\" id=\"m-sys-disk-bar\"></div></div>\n        </div>\n        <!-- Load avg -->\n        <div class=\"alpha-stat-card\">\n          <div class=\"alpha-stat-card-title\">LOAD AVG (1m)</div>\n          <div class=\"alpha-stat-big\" id=\"m-sys-load-val\">—</div>\n        </div>\n      </div>\n    </div>\n\n  <!-- Bottom navigation -->\n  <div id=\"alpha-bottom-nav\">\n    <button class=\"alpha-nav-btn active\" id=\"alpha-nav-graph\" onclick=\"alphaShowTab('graph')\">\n      <span class=\"nav-icon\">◈</span>\n      <span>GRAPH</span>\n    </button>\n    <button class=\"alpha-nav-btn\" id=\"alpha-nav-feed\" onclick=\"alphaShowTab('feed')\">\n      <span class=\"nav-icon\"><svg width=\"11\" height=\"14\" viewBox=\"0 0 11 14\" fill=\"none\" style=\"vertical-align:middle;margin-right:3px;position:relative;top:-1px\"><path d=\"M6.5 1L1 8h4.5L4.5 13 10 6H5.5L6.5 1z\" fill=\"#E8E8E8\"/></svg></span>\n      <span>FEED</span>\n    </button>\n    <button class=\"alpha-nav-btn\" id=\"alpha-nav-stats\" onclick=\"alphaShowTab('stats')\">\n      <span class=\"nav-icon\">📊</span>\n      <span>STATS</span>\n    </button>\n    <button class=\"alpha-nav-btn\" id=\"alpha-nav-tools\" onclick=\"alphaShowTab('tools')\">\n      <span class=\"nav-icon\">⚙</span>\n      <span>TOOLS</span>\n    </button>\n    <button class=\"alpha-nav-btn\" id=\"alpha-nav-crons\" onclick=\"alphaShowTab('crons')\">\n      <span class=\"nav-icon\">⏱</span>\n      <span>CRONS</span>\n    </button>\n    <button class=\"alpha-nav-btn\" id=\"alpha-nav-system\" onclick=\"alphaShowTab('system')\">\n      <span class=\"nav-icon\">🖥</span>\n      <span>SYS</span>\n    </button>\n</div>\n\n<!-- Unified Drawer -->\n<div id=\"unified-drawer\" style=\"display:none; position:fixed; z-index:300; background:#111114; border:1px solid #222228;\">\n  <div id=\"unified-drawer-handle\" style=\"width:40px;height:4px;background:#333;border-radius:2px;margin:8px auto;display:none;\"></div>\n  <div style=\"display:flex;justify-content:space-between;align-items:center;padding:12px 16px 8px;\">\n    <span id=\"unified-drawer-title\" style=\"color:#B87333;font-weight:700;font-family:'JetBrains Mono',monospace;font-size:13px;\"></span>\n    <button onclick=\"closeUnifiedDrawer()\" style=\"background:none;border:none;color:#888;cursor:pointer;font-size:18px;\">✕</button>\n  </div>\n  <div id=\"unified-drawer-body\" style=\"padding:0 16px 16px;font-family:'JetBrains Mono',monospace;font-size:12px;overflow-y:auto;\"></div>\n</div>\n\n<!-- FAB Filtri -->\n<button id=\"mobile-fab-filters\" onclick=\"openMobileFilters()\" style=\"display:none; position:fixed; bottom:80px; right:16px; z-index:600; width:48px; height:48px; border-radius:50%; background:#B87333; border:none; font-size:20px; cursor:pointer; box-shadow:0 4px 12px rgba(184,115,51,0.4); align-items:center; justify-content:center;\">⚙️</button>\n\n<!-- Mobile Filters Sheet -->\n<div id=\"mobile-filters-sheet\" style=\"display:none; position:fixed; bottom:0; left:0; right:0; background:#111114; border-top:2px solid #B87333; border-radius:16px 16px 0 0; z-index:700; padding:20px; font-family:'JetBrains Mono',monospace;\">\n  <div style=\"display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;\">\n    <span style=\"color:#B87333; font-size:16px; font-weight:700;\">⚙️ Filters</span>\n    <button onclick=\"closeMobileFilters()\" style=\"background:none; border:none; color:#888; font-size:20px; cursor:pointer;\">✕</button>\n  </div>\n  <div id=\"mobile-filters-content\">\n    <div style=\"display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #222228;\">\n      <span style=\"font-size:13px; color:#E8E8E8;\">⏱ Cron</span>\n      <button id=\"m-filter-cron\" class=\"filter-btn\" onclick=\"toggleFilter('cron')\">OFF</button>\n    </div>\n    <div style=\"display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #222228;\">\n      <span style=\"font-size:13px; color:#E8E8E8;\"><svg width=\"11\" height=\"14\" viewBox=\"0 0 11 14\" fill=\"none\" style=\"vertical-align:middle;margin-right:3px;position:relative;top:-1px\"><path d=\"M6.5 1L1 8h4.5L4.5 13 10 6H5.5L6.5 1z\" fill=\"#E8E8E8\"/></svg> Active only</span>\n      <button id=\"m-filter-active\" class=\"filter-btn\" onclick=\"toggleFilter('active')\">ON</button>\n    </div>\n    <div style=\"display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #222228;\">\n      <span style=\"font-size:13px; color:#E8E8E8;\">🤖 Agent</span>\n      <select id=\"m-filter-agent\" class=\"filter-select\" onchange=\"changeFilterAgent(this.value)\" style=\"background:#18181c; border:1px solid #222228; color:#B87333; padding:6px; border-radius:4px; font-family:'JetBrains Mono'; font-size:11px;\"></select>\n    </div>\n    <div style=\"display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid #222228;\">\n      <span style=\"font-size:13px; color:#E8E8E8;\">📅 Period</span>\n      <div style=\"display:flex; gap:4px;\">\n        <button class=\"filter-btn\" id=\"m-period-1\" onclick=\"changePeriod(1)\">1d</button>\n        <button class=\"filter-btn active\" id=\"m-period-7\" onclick=\"changePeriod(7)\">7d</button>\n        <button class=\"filter-btn\" id=\"m-period-30\" onclick=\"changePeriod(30)\">30d</button>\n        <button class=\"filter-btn\" id=\"m-period-0\" onclick=\"changePeriod(0)\">all</button>\n      </div>\n    </div>\n  </div>\n  <button onclick=\"closeMobileFilters()\" style=\"width:100%; margin-top:24px; background:#B87333; border:none; color:#000; font-family:'JetBrains Mono'; font-weight:700; padding:12px; border-radius:8px; cursor:pointer;\">Close</button>\n</div>\n\n<!-- Graph fullscreen overlay (keep for compatibility) -->\n<div id=\"m-graph-overlay\">\n  <div id=\"m-graph-overlay-header\">\n    <span>AGENT GRAPH — live</span>\n    <button id=\"m-graph-close\" onclick=\"closeGraphFullscreen()\">✕</button>\n  </div>\n  <div id=\"m-graph-svg-container\"></div>\n</div>\n\n<div id=\"tooltip\">\n  <div class=\"tt-id\" id=\"tt-id\"></div>\n  <div class=\"tt-row\">model: <span id=\"tt-model\">—</span></div>\n  <div class=\"tt-row\">cost: <span id=\"tt-cost\">—</span></div>\n  <div class=\"tt-row\">status: <span id=\"tt-status\">—</span></div>\n  <div class=\"tt-row\" id=\"tt-task-row\" style=\"max-width:260px;word-break:break-word;display:none\">task: <span id=\"tt-task\" style=\"color:var(--text);font-style:italic\">—</span></div>\n</div>\n\n\n\n<div id=\"cost-override-modal\" style=\"display:none;position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:1000;align-items:center;justify-content:center;\">\n  <div style=\"background:#111114;border:1px solid #B87333;padding:24px;width:300px;\">\n    <div style=\"color:#B87333;font-size:10px;margin-bottom:16px;\">OVERRIDE REAL COST</div>\n    <input id=\"cost-override-input\" type=\"number\" step=\"0.01\" style=\"width:100%;background:#000;border:1px solid #333;color:#fff;padding:10px;margin-bottom:16px;\">\n    <div style=\"display:flex;gap:8px;\">\n      <button onclick=\"saveCostOverride()\" style=\"flex:1;background:#B87333;padding:10px;border:none;font-weight:700;\">SAVE</button>\n      <button onclick=\"closeCostOverride()\" style=\"flex:1;background:#333;color:#888;padding:10px;border:none;\">CLOSE</button>\n    </div>\n  </div>\n</div>";
const DASHBOARD_SCRIPT = "\nconst API_HEADERS = { 'Authorization': 'Bearer olympus2026' };\nlet sessionsData = [];\nlet costsData = {};\nlet agentsList = [];\nlet activeAgentFilter = 'ALL';\nlet showCron = false;\nlet showActiveOnly = true;\nlet nodePositions = new Map(); \nwindow._graphInitialized = false; \n// Time window filter: 1=1 day, 7=7 days, 30=30 days, 0=all\nlet timePeriodDays = 7;\n\nfunction isActive(session) {\n  const fiveMinAgo = Date.now() - (5 * 60 * 1000);\n  let updatedMs = session.updated_at;\n  if (updatedMs && updatedMs < 1e12) updatedMs = updatedMs * 1000; \n  return session.status === 'working' || session.status === 'active' || session.status === 'idle' || (updatedMs && updatedMs > fiveMinAgo);\n}\n\nfunction isHistoric(session) {\n  const twoMinutesAgo = Date.now() - (2 * 60 * 1000);\n  let updatedMs = session.updated_at;\n  if (updatedMs && updatedMs < 1e12) updatedMs = updatedMs * 1000; \n  const isOld = updatedMs && updatedMs < twoMinutesAgo;\n  const isDone = session.status === 'completed' || session.status === 'idle' || session.status === 'error';\n  return isOld && isDone && session.session_id.includes(':subagent:');\n}\n\nfunction isCron(sessionId) {\n  return sessionId && sessionId.includes(':cron:');\n}\n\nfunction isWithinPeriod(session) {\n  if (timePeriodDays === 0) return true; // \"all\"\n  const cutoff = Date.now() - (timePeriodDays * 24 * 60 * 60 * 1000);\n  let startedMs = session.started_at;\n  if (startedMs && startedMs < 1e12) startedMs = startedMs * 1000;\n  // If no started_at, include by default (active sessions)\n  if (!startedMs) return true;\n  return startedMs >= cutoff;\n}\n\nfunction updateClock() {\n  const now = new Date();\n  document.getElementById('clock').textContent = now.toLocaleString('it-IT', {\n    day: '2-digit', month: '2-digit', year: 'numeric',\n    hour: '2-digit', minute: '2-digit', second: '2-digit'\n  });\n}\nsetInterval(updateClock, 1000);\nupdateClock();\n\nfunction fmtCost(v) {\n  if (!v) return '$0.0000';\n  return '$' + (+v).toFixed(4);\n}\n\nfunction extractAgentId(sessionId) {\n  const parts = (sessionId || '').split(':');\n  return parts[1] || 'unknown';\n}\n\nfunction shouldShowInFeed(event) {\n  // Apply cron filter: hide cron events when cron filter is OFF\n  if (!showCron && isCron(event.session_id)) return false;\n  if (activeAgentFilter === 'ALL') return true;\n  const eventAgentId = extractAgentId(event.session_id);\n  return eventAgentId === activeAgentFilter;\n}\n\nfunction virtualNodeLabel(agentId) {\n  if (!agentId || agentId === '__root__') return '◈ Olympus';\n  const id = agentId.replace(/^__agent__:?/, '').replace(/^__root__/, '');\n  if (!id) return '◈ Olympus';\n  return '◈ ' + id.charAt(0).toUpperCase() + id.slice(1);\n}\n\nfunction shortLabel(sessionId) {\n  if (!sessionId || sessionId === '__root__') return 'Olympus';\n  if (sessionId.startsWith('__agent__:')) return sessionId.replace('__agent__:', '');\n  const parts = sessionId.split(':');\n  if (parts.length >= 4) {\n    const type = parts[2];\n    const tail = parts[3] ? parts[3].slice(0, 6) : '';\n    return `${type}:${tail}`;\n  } else if (parts.length === 3) {\n    return `${parts[1]}:${parts[2]}`;\n  }\n  return sessionId.slice(0, 16);\n}\n\nfunction extractNodeName(session) {\n  if (session._virtual) return virtualNodeLabel(session.session_id);\n  const id = session.session_id || '';\n\n  // 1. Use label explicitly declared via lineage.js (highest priority)\n  if (session.label && !session.label.startsWith('agent:')) return session.label;\n\n  const task = (session.task_preview || '').trim();\n\n  const seiMatch = task.match(/^Sei\\s+(?:il\\s+|la\\s+|l['\\'])?([A-Za-z][A-Za-zÀ-ÿ\\/\\-]{0,20}(?:\\s+[A-Za-z][A-Za-zÀ-ÿ\\/\\-]{0,20}){0,2})/i);\n  if (seiMatch) return seiMatch[1].trim();\n\n  const youMatch = task.match(/^You are\\s+(?:the\\s+)?([A-Za-z][A-Za-z\\s\\/\\-]{0,30})/i);\n  if (youMatch) return youMatch[1].trim().split('\\n')[0];\n\n  const knownAgents = ['Argus', 'Atlas', 'Hermes', 'Mercury', 'Forge', 'Olympus'];\n  for (const agent of knownAgents) {\n    if (task.includes(agent)) return agent;\n  }\n\n  if (id.includes(':main')) {\n    const agent = id.split(':')[1] || 'Main';\n    return agent.charAt(0).toUpperCase() + agent.slice(1);\n  }\n  if (id.includes(':cron:')) return '⏱ Cron';\n  if (id.includes(':slash:')) return '/ Slash';\n  if (id.includes(':telegram:')) return '💬 Telegram';\n  if (id.includes(':subagent:')) {\n    const agentPart = id.split(':')[1] || '';\n    if (agentPart && agentPart !== 'website') return agentPart.charAt(0).toUpperCase() + agentPart.slice(1) + ' Agent';\n    return 'Sub-' + id.split(':subagent:')[1].slice(0,4);\n  }\n\n  return id.slice(0, 10);\n}\n\nfunction renderAgentToolbar(agents) {\n  const toolbar = document.getElementById('agent-toolbar');\n  toolbar.innerHTML = '<span class=\"agent-filter-label\">AGENT:</span>';\n\n  const cronBtn = document.createElement('button');\n  cronBtn.className = 'agent-btn' + (showCron ? ' active' : '');\n  cronBtn.textContent = showCron ? '⏱ cron: ON' : '⏱ cron: OFF';\n  cronBtn.style.marginLeft = 'auto';\n  cronBtn.onclick = () => { showCron = !showCron; syncFiltersToUrl(); renderAgentToolbar(agentsList); initGraph(sessionsData); if (window._lastEvents) renderFeed(window._lastEvents); };\n\n  const activeBtn = document.createElement('button');\n  activeBtn.className = 'agent-btn' + (showActiveOnly ? ' active' : '');\n  const boltSvg = '<svg width=\"11\" height=\"14\" viewBox=\"0 0 11 14\" fill=\"none\" style=\"vertical-align:middle;margin-right:3px;position:relative;top:-1px\"><path d=\"M6.5 1L1 8h4.5L4.5 13 10 6H5.5L6.5 1z\" fill=\"#E8E8E8\"/></svg>';\n  activeBtn.innerHTML = boltSvg + (showActiveOnly ? ' active only: ON' : ' active only: OFF');\n  activeBtn.style.marginLeft = '4px';\n  if (showActiveOnly) activeBtn.style.borderColor = '#22c55e';\n  activeBtn.onclick = () => {\n    showActiveOnly = !showActiveOnly;\n    syncFiltersToUrl();\n    renderAgentToolbar(agentsList);\n    initGraph(sessionsData);\n    if (window._lastEvents) renderFeed(window._lastEvents);\n  };\n\n  const resetBtn = document.createElement('button');\n  resetBtn.className = 'agent-btn';\n  resetBtn.textContent = '⊙ Reset zoom';\n  resetBtn.style.marginLeft = '4px';\n  resetBtn.onclick = () => { window._zoomReset && window._zoomReset(); };\n\n  const allBtn = document.createElement('button');\n  allBtn.className = 'agent-btn' + (activeAgentFilter === 'ALL' ? ' active' : '');\n  allBtn.textContent = 'ALL';\n  allBtn.onclick = () => { activeAgentFilter = 'ALL'; syncFiltersToUrl(); renderAgentToolbar(agentsList); initGraph(sessionsData); if (window._lastEvents) renderFeed(window._lastEvents); };\n  toolbar.appendChild(allBtn);\n\n  agents.forEach(agentId => {\n    const btn = document.createElement('button');\n    btn.className = 'agent-btn' + (activeAgentFilter === agentId ? ' active' : '');\n    btn.textContent = agentId;\n    btn.onclick = () => { activeAgentFilter = agentId; syncFiltersToUrl(); renderAgentToolbar(agentsList); initGraph(sessionsData); if (window._lastEvents) renderFeed(window._lastEvents); };\n    toolbar.appendChild(btn);\n  });\n\n  // PERIOD FILTER — finestra temporale\n  const periodLabel = document.createElement('span');\n  periodLabel.style.cssText = 'margin-left:8px; color:#666; font-size:11px; font-family:JetBrains Mono,monospace; white-space:nowrap;';\n  periodLabel.textContent = 'Period:';\n  const periodOptions = [{label:'1d', val:1},{label:'7d', val:7},{label:'30d', val:30},{label:'all', val:0}];\n  const periodBtns = periodOptions.map(opt => {\n    const b = document.createElement('button');\n    b.className = 'agent-btn' + (timePeriodDays === opt.val ? ' active' : '');\n    b.textContent = opt.label;\n    b.style.marginLeft = '2px';\n    if (timePeriodDays === opt.val) b.style.borderColor = '#B87333';\n    b.onclick = () => { timePeriodDays = opt.val; syncFiltersToUrl(); renderAgentToolbar(agentsList); initGraph(sessionsData); };\n    return b;\n  });\n\n  toolbar.appendChild(cronBtn);\n  toolbar.appendChild(activeBtn);\n  toolbar.appendChild(periodLabel);\n  periodBtns.forEach(b => toolbar.appendChild(b));\n  toolbar.appendChild(resetBtn);\n\n  let costDisplay = document.getElementById('cost-display');\n  if (!costDisplay) {\n    costDisplay = document.createElement('div');\n    costDisplay.id = 'cost-display';\n    costDisplay.style.cssText = 'margin-left:auto; color:#B87333; font-size:12px; font-family:JetBrains Mono,monospace; white-space:nowrap; padding:0 8px;';\n    costDisplay.innerHTML = '~$<span id=\"cost-estimated\">...</span> <span style=\"color:#555;font-size:10px;\">estimated</span> <span style=\"color:#444;margin:0 6px;\">|</span> $<span id=\"cost-real\">—</span> <span style=\"color:#555;font-size:10px;\">real GitHub</span> <button onclick=\"openCostOverride()\" style=\"background:none;border:1px solid #333;color:#888;font-size:9px;font-family:JetBrains Mono,monospace;padding:2px 6px;border-radius:4px;cursor:pointer;margin-left:6px;\">✏️</button> <a href=\"https://github.com/settings/billing/summary\" target=\"_blank\" style=\"color:#555;font-size:9px;font-family:JetBrains Mono,monospace;margin-left:4px;text-decoration:none;\">↗ GitHub</a>';\n    toolbar.appendChild(costDisplay);\n  }\n}\n\nfunction buildTreeData(sessions, filterAgent) {\n  let visible = sessions || [];\n\n  // TIME PERIOD FILTER — applicato prima di tutto il resto\n  if (timePeriodDays > 0) {\n    const cutoff = Date.now() - (timePeriodDays * 24 * 60 * 60 * 1000);\n    visible = visible.filter(s => {\n      let updatedMs = s.updated_at;\n      if (updatedMs && updatedMs < 1e12) updatedMs = updatedMs * 1000;\n      if (!updatedMs) return true; // sessioni senza data → includi (probabilmente attive)\n      return updatedMs >= cutoff;\n    });\n  }\n\n  // AGGIUNTO: quando showActiveOnly, escludi sessioni con agentId non in agentsList\n  if (showActiveOnly && agentsList.length > 0) {\n    visible = visible.filter(s => {\n      const parts = s.session_id?.split(':') || [];\n      const agentId = parts.length >= 2 ? parts[1] : 'unknown';\n      // Keep session if agentId is in agentsList OR if it's a cron/subagent child of an active agent\n      return agentsList.includes(agentId) || \n             s.session_id?.includes('subagent') || \n             s.session_id?.includes('cron');\n    });\n  }\n\n  if (filterAgent && filterAgent !== 'ALL') {\n    visible = visible.filter(s => extractAgentId(s.session_id) === filterAgent);\n  }\n  // cron filter: if cron OFF hide all cron; if cron ON hide inactive cron\n  visible = visible.filter(s => {\n    if (isCron(s.session_id)) {\n      if (!showCron) return false;\n      // cron ON → show only active cron\n      if (!isActive(s)) return false;\n    }\n    return true;\n  });\n  // Strictly active = live status AND updated within staleness window\n  // Sessions that disappear from OpenClaw API stay \"idle\" forever → staleness check fixes this\n  // NOTE: 'working' sessions are NEVER stale regardless of updated_at (daemon may not heartbeat tokens)\n  const STALE_MS = 60 * 60 * 1000;       // 1 hour for subagents/crons\n  const STALE_MS_MAIN = 8 * 60 * 60 * 1000; // 8 hours for :main sessions (idle waiting for human input)\n  const now = Date.now();\n  const isStrictlyActive = s => {\n    if (s.status === 'completed' || s.status === 'error') return false;\n    // 'working' sessions are always considered active (explicit daemon marking)\n    if (s.status === 'working') return true;\n    const updMs = s.updated_at < 1e12 ? s.updated_at * 1000 : (s.updated_at || 0);\n    // Main sessions (human-interactive) can be idle for much longer — use extended stale threshold\n    const stale = (s.session_id && s.session_id.endsWith(':main')) ? STALE_MS_MAIN : STALE_MS;\n    return (now - updMs) < stale;\n  };\n  const isTerminated = s => s.status === 'completed' || s.status === 'error' ||\n    (() => { \n      if (s.status === 'working') return false; // working sessions never terminated\n      const updMs = s.updated_at < 1e12 ? s.updated_at * 1000 : (s.updated_at || 0); const stale = (s.session_id && s.session_id.endsWith(':main')) ? STALE_MS_MAIN : STALE_MS; return (now - updMs) >= stale; })();\n\n  // Grace period: completed sessions shown for max 3 minutes after ending, then removed\n  const GRACE_MS = 30 * 1000; // 30 seconds\n  const isInGracePeriod = s => {\n    if (!isTerminated(s)) return false;\n    const endedAt = s.ended_at || s.updated_at || 0;\n    const ts = endedAt < 1e12 ? endedAt * 1000 : endedAt;\n    return (now - ts) < GRACE_MS;\n  };\n  // Mark grace period sessions for visual fade\n  visible.forEach(s => { s._grace = isInGracePeriod(s); });\n\n  // active only ON → show working/idle + grace period fading out\n  // active only OFF → show everything (no filter)\n  if (showActiveOnly) {\n      const activeIds = new Set(visible.filter(s => isStrictlyActive(s)).map(s => s.session_id));\n      visible = visible.filter(s => isStrictlyActive(s) || s._grace || (s.parent_id && activeIds.has(s.parent_id) && (isStrictlyActive(s) || s._grace)));\n  }\n  // else: no filter — show everything\n\n  const byId = {};\n  visible.forEach(s => { byId[s.session_id] = { ...s, name: extractNodeName(s), children: [] }; });\n\n  // Includi SOLO le sessioni padre strettamente necessarie per agganciare figli visibili.\n  if (window._allSessions && !showActiveOnly) {\n    // Raccogliamo i parent_id mancanti tra le sessioni visibili\n    const neededParents = new Set();\n    visible.forEach(s => {\n      if (s.parent_id && !byId[s.parent_id]) neededParents.add(s.parent_id);\n    });\n    window._allSessions.forEach(s => {\n      if (neededParents.has(s.session_id) && !byId[s.session_id]) {\n        byId[s.session_id] = { ...s, name: extractNodeName(s), children: [], _hidden: true };\n      }\n    });\n  }\n\n  const agentGroups = {};\n  visible.forEach(s => {\n    const aid = extractAgentId(s.session_id);\n    if (!agentGroups[aid]) agentGroups[aid] = [];\n    agentGroups[aid].push(s);\n  });\n\n  const root = { name: '◈ Olympus', session_id: '__root__', children: [], _virtual: true };\n  \n  Object.keys(agentGroups).forEach(aid => {\n    const agentSessions = agentGroups[aid];\n\n    // Trova la sessione :main dell'agent (radice reale del gruppo)\n    const mainSession = agentSessions.find(s => s.session_id.endsWith(':main'));\n\n    // Se esiste una :main, usala direttamente come nodo radice (no duplicato virtuale)\n    // Altrimenti crea il nodo virtuale come fallback\n    let agentNode;\n    if (mainSession) {\n      agentNode = byId[mainSession.session_id];\n      root.children.push(agentNode);\n    } else {\n      const vId = `__agent__:${aid}`;\n      agentNode = { name: virtualNodeLabel(aid), session_id: vId, children: [], _virtual: true };\n      root.children.push(agentNode);\n    }\n\n    agentSessions.forEach(s => {\n      // Skip :main — it's already the root node, should not be added as its own child\n      if (mainSession && s.session_id === mainSession.session_id) return;\n\n      const parentNode = s.parent_id ? byId[s.parent_id] : null;\n      if (parentNode && !parentNode._virtual && !parentNode._hidden) {\n        // Padre reale trovato e visibile\n        parentNode.children.push(byId[s.session_id]);\n      } else if (parentNode && !parentNode._virtual && parentNode._hidden) {\n        // Padre reale ma nascosto (completato) — aggancia comunque\n        parentNode.children.push(byId[s.session_id]);\n        if (!agentSessions.find(x => x.session_id === parentNode.session_id)) {\n          agentNode.children.push(parentNode);\n        }\n      } else {\n        agentNode.children.push(byId[s.session_id]);\n      }\n    });\n  });\n\n  return root;\n}\n\nfunction initGraphOnce() {\n  const svg = d3.select('#graph-svg');\n  svg.selectAll('#graph-group').remove(); // remove any existing group before creating new one\n  const g = svg.append('g').attr('id', 'graph-group');\n  const zoom = d3.zoom().scaleExtent([0.05, 4]).filter(event => {\n    // D3 v7 uses pointerdown (not mousedown) — must handle all pointer/mouse/touch variants.\n    // Block zoom/drag when clicking directly on node elements so click & hover work.\n    if (event.type === 'pointerdown' || event.type === 'mousedown' || event.type === 'touchstart') {\n      const tag = (event.target.tagName || '').toLowerCase();\n      if (tag === 'circle' || tag === 'text' || tag === 'tspan') return false;\n      return true;\n    }\n    return event.type === 'wheel';\n  }).on('zoom', e => g.attr('transform', e.transform));\n  svg.call(zoom);\n  window._graphZoom = zoom;\n  window._graphGroup = g;\n  window._graphSvg = svg;\n  window._graphInitialized = true;\n}\n\nfunction fitGraphToContent() {\n  try {\n    const g = document.getElementById('graph-group');\n    const el = document.getElementById('graph-svg');\n    const bbox = g.getBBox();\n    const W = el.getBoundingClientRect().width;\n    const H = el.getBoundingClientRect().height;\n    const pad = 40;\n    const scale = Math.min((W - pad*2)/bbox.width, (H - pad*2)/bbox.height, 1.5);\n    const tx = W/2 - (bbox.x + bbox.width/2) * scale;\n    const ty = H/2 - (bbox.y + bbox.height/2) * scale;\n    window._graphSvg.transition().duration(750).call(\n      window._graphZoom.transform,\n      d3.zoomIdentity.translate(tx, ty).scale(scale)\n    );\n  } catch(e) {}\n}\nwindow._zoomReset = fitGraphToContent;\n\nfunction renderGraph(sessions) {\n  if (isMobile()) return;\n  if (!window._graphInitialized) {\n    initGraphOnce();\n    setTimeout(() => fitGraphToContent(), 1500);\n  }\n\n  const g = window._graphGroup;\n  g.selectAll('*').remove(); \n\n  const treeData = buildTreeData(sessions, activeAgentFilter);\n  const root = d3.hierarchy(treeData);\n  \n  const el = document.getElementById('graph-svg');\n  const rect = el.getBoundingClientRect();\n  const W = rect.width > 10 ? rect.width : (el.parentElement.getBoundingClientRect().width || 800);\n  const H = rect.height > 10 ? rect.height : (window.innerHeight - 60 || 600);\n\n  const treeLayout = d3.tree().size([H - 60, W - 120]);\n  treeLayout(root);\n\n  const linkGen = d3.linkHorizontal().x(d => d.y).y(d => d.x);\n\n  g.selectAll('.link')\n    .data(root.links())\n    .join('path')\n    .attr('class', 'link')\n    .attr('d', linkGen)\n    .attr('fill', 'none')\n    .attr('stroke', '#444')\n    .attr('stroke-width', 1.5);\n\n  const node = g.selectAll('.node')\n    .data(root.descendants())\n    .join('g')\n    .attr('class', d => `node ${d.data._virtual ? 'virtual' : (d.data.status || 'idle')}${d.data._grace ? ' grace' : ''}`)\n    .attr('transform', d => `translate(${d.y},${d.x})`)\n    .style('cursor', 'pointer')\n    .on('pointerdown', (event, d) => { event.stopPropagation(); })\n    .on('mousedown', (event, d) => { event.stopPropagation(); })\n    .on('click', (event, d) => { event.stopPropagation(); if (!d.data._virtual) openDrawer(d.data); })\n    .on('mousemove', (event, d) => {\n      const tt = document.getElementById('tooltip');\n      document.getElementById('tt-id').textContent = d.data.session_id;\n      document.getElementById('tt-model').textContent = d.data.model || '—';\n      document.getElementById('tt-cost').textContent = fmtCost(d.data.cost_usd);\n      document.getElementById('tt-status').textContent = d.data.status || '—';\n      const ttTaskRow = document.getElementById('tt-task-row');\n      if (d.data.task_preview) {\n        document.getElementById('tt-task').textContent = d.data.task_preview.substring(0, 120);\n        ttTaskRow.style.display = '';\n      } else { ttTaskRow.style.display = 'none'; }\n      tt.style.display = 'block';\n      tt.style.left = (event.clientX + 14) + 'px';\n      tt.style.top = (event.clientY - 10) + 'px';\n    })\n    .on('mouseleave', () => { document.getElementById('tooltip').style.display = 'none'; });\n\n  node.filter(d => d.data.status === 'working' || d.data.status === 'active')\n    .append('circle').attr('class', 'pulse-ring').attr('r', 10)\n    .attr('fill', 'none').attr('stroke', '#22c55e').attr('stroke-width', 1.5).attr('opacity', 0.6);\n\n  node.append('circle').attr('r', d => d.data._virtual ? 10 : 8);\n\n  node.append('text')\n    .text(d => d.data.name)\n    .attr('dy', 22)\n    .attr('text-anchor', 'middle')\n    .style('font-size', '10px')\n    .style('fill', d => d.data._virtual ? 'var(--copper)' : 'var(--text)');\n\n  node.filter(d => !d.data._virtual && d.data.cost_usd)\n    .append('text')\n    .attr('dy', 34)\n    .attr('text-anchor', 'middle')\n    .attr('class', 'cost-text')\n    .text(d => fmtCost(d.data.cost_usd));\n}\n\nfunction initGraph(sessions) { \n  renderGraph(sessions);\n  if (window._graphInitialized) setTimeout(fitGraphToContent, 100);\n}\n\nfunction renderFeed(events) {\n  const list = document.getElementById('feed-list');\n  if (!list) return; // Added safety for mobile\n  list.innerHTML = '';\n  const filtered = events.filter(ev => shouldShowInFeed(ev));\n  filtered.slice(0, 20).forEach(ev => {\n    const div = document.createElement('div');\n    div.className = 'feed-item';\n    const typeClass = ['spawn','complete','error','tool_call'].includes(ev.type) ? ev.type : '';\n    const feedLabel = (ev.label && !ev.label.startsWith('agent:')) ? ev.label : shortLabel(ev.session_id);\n    div.innerHTML = `<span class=\"fi-ts\">${fmtTs(ev.ts)}</span><span class=\"fi-type ${typeClass}\">${ev.type}</span><span class=\"fi-label\">${feedLabel}</span>`;\n    list.appendChild(div);\n  });\n}\n\nfunction renderCosts(costs) {\n  document.getElementById('hdr-cost').textContent = fmtCost(costs.today);\n  document.getElementById('hdr-alltime').textContent = fmtCost(costs.allTime);\n  const rows = document.getElementById('cost-rows');\n  rows.innerHTML = '';\n  (costs.byModel || []).forEach(m => {\n    const div = document.createElement('div');\n    div.className = 'cost-row';\n    div.innerHTML = `<span class=\"model-name\">${abbreviate(m.model || 'unknown', 30)}</span><span class=\"model-cost\">${fmtCost(m.cost)}</span>`;\n    rows.appendChild(div);\n  });\n}\n\nasync function refreshWithMobile() {\n  const ind = document.getElementById('refresh-indicator');\n  ind.style.color = '#B87333';\n  try {\n    const [sRes, cRes, eRes, aRes] = await Promise.all([\n      fetch('/api/sessions', { headers: API_HEADERS }),\n      fetch('/api/costs', { headers: API_HEADERS }),\n      fetch('/api/events?limit=50', { headers: API_HEADERS }),\n      fetch('/api/agents', { headers: API_HEADERS }),\n    ]);\n    sessionsData = await sRes.json();\n    window._allSessions = sessionsData; // cache per gerarchia lineage\n    costsData = await cRes.json();\n    const events = await eRes.json();\n    agentsList = await aRes.json();\n\n    document.getElementById('hdr-sessions').textContent = sessionsData.length;\n    renderAgentToolbar(agentsList);\n    if (!window._graphInitialized) {\n      renderGraph(sessionsData);\n      setTimeout(() => { window._zoomReset && window._zoomReset(); }, 300);\n      window._graphInitialized = true;\n    } else {\n      renderGraph(sessionsData);\n    }\n    renderFeed(events);\n    window._lastEvents = events;\n\n    const fab = document.getElementById('mobile-fab-filters');\n    if (fab) {\n      fab.style.display = isMobile() ? 'flex' : 'none';\n    }\n\n    // Populate agent select in mobile filters\n    const mAgentSelect = document.getElementById('m-filter-agent');\n    if (mAgentSelect && agentsList.length > 0) {\n      const current = mAgentSelect.value || activeAgentFilter;\n      mAgentSelect.innerHTML = '<option value=\"ALL\">ALL</option>';\n      agentsList.forEach(a => {\n        const opt = document.createElement('option');\n        opt.value = a;\n        opt.textContent = a;\n        mAgentSelect.appendChild(opt);\n      });\n      mAgentSelect.value = current;\n    }\n\n    fetch('/api/stats', { headers: API_HEADERS }).then(r=>r.json()).then(data => {\n      const estimated = (data.total?.total||0).toFixed(4);\n      const elEst = document.getElementById('cost-estimated');\n      const elAlphaEst = document.getElementById('alpha-cost-estimated');\n      if (elEst) elEst.textContent = estimated;\n      if (elAlphaEst) elAlphaEst.textContent = estimated;\n      renderAlpha();\n      if (window._overrideTs !== undefined && window._costOverride !== undefined) {\n        fetch('/api/stats-since?ts=' + window._overrideTs, { headers: API_HEADERS })\n          .then(r => r.json())\n          .then(deltaData => {\n            const delta = deltaData.total || 0;\n            const reale = window._costOverride + delta;\n            const elReal = document.getElementById('cost-real');\n            const elAlphaReal = document.getElementById('alpha-cost-real');\n            if (elReal) elReal.textContent = reale.toFixed(2) + ' real (~+$' + delta.toFixed(2) + ' today)';\n            if (elAlphaReal) elAlphaReal.textContent = reale.toFixed(2) + ' (~+$' + delta.toFixed(2) + ')';\n          }).catch(() => {});\n      }\n    }).catch(() => renderAlpha());\n\n    ind.style.color = '#22c55e';\n  } catch (e) { ind.style.color = '#ef4444'; console.error('Refresh error:', e); }\n  setTimeout(() => { ind.style.color = '#4b5563'; }, 2000);\n}\n\nfunction syncFiltersToUrl() {\n  const params = new URLSearchParams();\n  params.set('cron', showCron ? '1' : '0');\n  params.set('active', showActiveOnly ? '1' : '0');\n  params.set('period', String(timePeriodDays));\n  if (activeAgentFilter !== 'ALL') params.set('agent', activeAgentFilter);\n  history.replaceState(null, '', '?' + params.toString());\n}\n\nfunction loadFiltersFromUrl() {\n  const params = new URLSearchParams(window.location.search);\n  if (params.has('cron'))    showCron          = params.get('cron')    === '1';\n  if (params.has('active'))  showActiveOnly    = params.get('active')  === '1';\n  if (params.has('period'))  timePeriodDays    = parseInt(params.get('period'), 10);\n  if (params.has('agent'))   activeAgentFilter = params.get('agent');\n}\n\nsetTimeout(function() {\n  loadFiltersFromUrl();\n  refreshWithMobile();\n  setInterval(refreshWithMobile, 10000);\n}, 0);\n\n// ===================== MOBILE JS — ALPHA =====================\nfunction isMobile() { return window.innerWidth <= 768; }\nlet alphaCurrentTab = 'graph';\n\nfunction alphaShowTab(tab) {\n  alphaCurrentTab = tab;\n  document.querySelectorAll('.alpha-tab-pane').forEach(p => p.classList.remove('active'));\n  document.querySelectorAll('.alpha-nav-btn').forEach(b => b.classList.remove('active'));\n  const tabPane = document.getElementById(`alpha-tab-${tab}`);\n  const navBtn = document.getElementById(`alpha-nav-${tab}`);\n  if (tabPane) tabPane.classList.add('active');\n  if (navBtn) navBtn.classList.add('active');\n  if (tab === 'graph') renderAlphaGraph();\n}\n\nfunction alphaToggleActive() {\n  showActiveOnly = !showActiveOnly;\n  const btn = document.getElementById('alpha-active-btn');\n  const boltSvg2 = '<svg width=\"11\" height=\"14\" viewBox=\"0 0 11 14\" fill=\"none\" style=\"vertical-align:middle;margin-right:3px;position:relative;top:-1px\"><path d=\"M6.5 1L1 8h4.5L4.5 13 10 6H5.5L6.5 1z\" fill=\"#E8E8E8\"/></svg>';\n  btn.innerHTML = boltSvg2 + (showActiveOnly ? ' active only: ON' : ' active only: OFF');\n  btn.classList.toggle('on', showActiveOnly);\n  renderAlpha();\n}\n\nfunction openAlphaSheet(session) { openUnifiedDrawer(session); }\n\nfunction closeAlphaSheet() { closeUnifiedDrawer(); }\n\nfunction renderAlphaGraph() {\n  const el = document.getElementById('alpha-graph-svg');\n  const rect = el.getBoundingClientRect();\n  const W = rect.width || window.innerWidth;\n  const H = (rect.height > 100) ? rect.height : (window.innerHeight - 150);\n  \n  const svg = d3.select('#alpha-graph-svg');\n  svg.selectAll('*').remove();\n  \n\n  const treeData = buildTreeData(sessionsData, activeAgentFilter);\n  const hasContent = treeData && treeData.children && treeData.children.length > 0;\n  \n  if (!hasContent) {\n    console.log('Alpha Graph: no children found in treeData', treeData);\n    svg.append('text')\n       .attr('x', W/2).attr('y', H/2)\n       .attr('text-anchor', 'middle')\n       .style('fill', '#444').style('font-size', '12px').text(sessionsData.length === 0 ? 'Loading data...' : 'No active sessions');\n    return;\n  }\n\n  const root = d3.hierarchy(treeData);\n  const treeLayout = d3.tree().size([W - 60, H - 120]);\n  treeLayout(root);\n\n  const g = svg.append('g');\n  const zoom = d3.zoom().scaleExtent([0.1, 4]).on('zoom', e => g.attr('transform', e.transform));\n  svg.call(zoom);\n\n  const linkGen = d3.linkVertical().x(d => d.x).y(d => d.y);\n\n  g.selectAll('.link').data(root.links()).join('path')\n    .attr('class', 'link')\n    .attr('d', linkGen)\n    .attr('fill', 'none')\n    .attr('stroke', '#444')\n    .attr('stroke-width', 1.5);\n\n  const node = g.selectAll('.node').data(root.descendants()).join('g')\n    .attr('class', d => `node ${d.data._virtual ? 'virtual' : (d.data.status || 'idle')}${d.data._grace ? ' grace' : ''}`)\n    .attr('transform', d => `translate(${d.x},${d.y})`)\n    .on('click', (e, d) => { if(!d.data._virtual) openAlphaSheet(d.data); });\n\n  node.filter(d => d.data.status === 'working' || d.data.status === 'active')\n    .append('circle').attr('class', 'pulse-ring').attr('r', 10)\n    .attr('fill', 'none').attr('stroke', '#22c55e').attr('stroke-width', 1.5).attr('opacity', 0.6);\n\n  node.append('circle').attr('r', d => d.data._virtual ? 10 : 8);\n\n  node.append('title').text(d => d.data.name); // tooltip on long-press / hover\n\n  node.append('text').text(d => {\n    const name = d.data.name || '';\n    // On mobile, truncate to avoid overlap: first word up to 8 chars, then ellipsis\n    if (name.length > 9) {\n      const firstWord = name.split(/[\\s\\-_]/)[0];\n      return firstWord.length <= 9 ? firstWord : firstWord.slice(0, 8) + '…';\n    }\n    return name;\n  })\n    .attr('dy', 22).attr('text-anchor', 'middle')\n    .style('font-size', '9px').style('fill', d => d.data._virtual ? 'var(--copper)' : 'var(--text)');\n\n  const bbox = g.node().getBBox();\n  if (bbox.width > 0 && bbox.height > 0) {\n    const scale = Math.min((W - 60) / bbox.width, (H - 120) / bbox.height, 1);\n    const tx = W/2 - (bbox.x + bbox.width/2) * scale;\n    const ty = H/2 - (bbox.y + bbox.height/2) * scale;\n    svg.call(zoom.transform, d3.zoomIdentity.translate(tx, ty).scale(scale));\n  } else {\n    g.attr('transform', `translate(${W/2}, 50)`);\n  }\n}\n\nfunction renderAlphaFeed() {\n  const list = document.getElementById('alpha-feed-list');\n  if (!list) return;\n  list.innerHTML = '';\n  const visible = showActiveOnly ? sessionsData.filter(s => isActive(s)) : sessionsData;\n  visible.slice(0, 20).forEach(s => {\n    const div = document.createElement('div');\n    div.className = 'alpha-feed-item';\n    div.innerHTML = `<div class=\"alpha-feed-dot\" style=\"background:${s.status==='working'?'#22c55e':'#4b5563'}\"></div><div class=\"alpha-feed-name\">${extractNodeName(s)}</div><div class=\"alpha-feed-status\">${s.status||'idle'}</div><div class=\"alpha-feed-cost\">${fmtCost(s.cost_usd)}</div>`;\n    div.onclick = () => openAlphaSheet(s);\n    list.appendChild(div);\n  });\n}\n\nfunction renderAlphaStats() {\n  document.getElementById('alpha-total-sessions').textContent = sessionsData.length;\n  document.getElementById('alpha-active-count').textContent = sessionsData.filter(s => isActive(s)).length + ' active';\n  const breakdown = document.getElementById('alpha-model-breakdown');\n  breakdown.innerHTML = '';\n  (costsData.byModel || []).slice(0, 5).forEach(m => {\n    const div = document.createElement('div');\n    div.className = 'alpha-model-row';\n    div.innerHTML = `<span class=\"alpha-model-name\">${m.model}</span><span class=\"alpha-model-cost\">${fmtCost(m.cost)}</span>`;\n    breakdown.appendChild(div);\n  });\n}\n\nfunction renderAlpha() {\n  const alphaReal = document.getElementById('alpha-cost-real');\n  if (alphaReal) alphaReal.textContent = window._costOverride ? window._costOverride.toFixed(2) : '—';\n  \n  // Sync mobile filter buttons state\n  const btnCron = document.getElementById('m-filter-cron');\n  const btnActive = document.getElementById('m-filter-active');\n  const selAgent = document.getElementById('m-filter-agent');\n  \n  if (btnCron) { btnCron.textContent = showCron ? 'ON' : 'OFF'; btnCron.classList.toggle('active', showCron); }\n  if (btnActive) { btnActive.textContent = showActiveOnly ? 'ON' : 'OFF'; btnActive.classList.toggle('active', showActiveOnly); }\n  if (selAgent) { selAgent.value = activeAgentFilter; }\n\n  if (alphaCurrentTab === 'graph') {\n    const visible = showActiveOnly ? sessionsData.filter(s => isActive(s)) : sessionsData;\n    if (visible.length === 0 && sessionsData.length > 0 && showActiveOnly) {\n    }\n    renderAlphaGraph();\n  }\n  renderAlphaFeed();\n  renderAlphaStats();\n}\n\nfunction openMobileFilters() { \n  document.getElementById('mobile-filters-sheet').style.display = 'block';\n  // Sync period buttons visual state\n  [1,7,30,0].forEach(v => {\n    const b = document.getElementById('m-period-' + v);\n    if (b) { b.classList.toggle('active', timePeriodDays === v); }\n  });\n}\nfunction closeMobileFilters() { document.getElementById('mobile-filters-sheet').style.display = 'none'; }\nfunction changePeriod(days) {\n  timePeriodDays = days;\n  [1,7,30,0].forEach(v => {\n    const b = document.getElementById('m-period-' + v);\n    if (b) b.classList.toggle('active', timePeriodDays === v);\n  });\n  syncFiltersToUrl();\n  renderAgentToolbar(agentsList);\n  initGraph(sessionsData);\n  renderAlpha();\n}\nfunction toggleFilter(type) {\n  if (type === 'cron') showCron = !showCron;\n  else if (type === 'active') showActiveOnly = !showActiveOnly;\n  \n  // Update button visual state immediately\n  if (type === 'cron') document.getElementById('m-filter-cron').textContent = showCron ? 'ON' : 'OFF';\n  if (type === 'active') document.getElementById('m-filter-active').textContent = showActiveOnly ? 'ON' : 'OFF';\n  \n  document.getElementById('m-filter-cron').classList.toggle('active', showCron);\n  document.getElementById('m-filter-active').classList.toggle('active', showActiveOnly);\n\n  syncFiltersToUrl();\n  renderAlpha();\n}\nfunction changeFilterAgent(v) { \n  activeAgentFilter = v; \n  syncFiltersToUrl(); \n  renderAlpha(); \n  if (window._lastEvents) renderFeed(window._lastEvents);\n}\n\n// ===================== UTILS =====================\nfunction openUnifiedDrawer(session) {\n  const name = extractNodeName(session);\n  document.getElementById('unified-drawer-title').textContent = name;\n  document.getElementById('unified-drawer-body').innerHTML = `\n    <div style=\"margin-bottom:12px;\"><div style=\"color:#555;font-size:10px;margin-bottom:2px;\">STATUS</div><div style=\"color:${session.status==='working'?'#22c55e':'#888'};\">● ${session.status||'idle'}</div></div>\n    <div style=\"margin-bottom:12px;\"><div style=\"color:#555;font-size:10px;margin-bottom:2px;\">MODEL</div><div>${session.model||'—'}</div></div>\n    <div style=\"margin-bottom:12px;\"><div style=\"color:#555;font-size:10px;margin-bottom:2px;\">COST</div><div style=\"color:#B87333;font-weight:700;\">${fmtCost(session.cost_usd)}</div></div>\n    <div style=\"margin-bottom:12px;\"><div style=\"color:#555;font-size:10px;margin-bottom:2px;\">SESSION ID</div><div style=\"color:#555;font-size:10px;word-break:break-all;\">${session.session_id||'—'}</div></div>\n    <div><div style=\"color:#555;font-size:10px;margin-bottom:2px;\">TASK</div><div style=\"color:#888;font-size:10px;line-height:1.4;\">${(session.task_preview||'—').substring(0,300)}</div></div>\n  `;\n  const drawer = document.getElementById('unified-drawer');\n  const handle = document.getElementById('unified-drawer-handle');\n  const body = document.getElementById('unified-drawer-body');\n  if (isMobile()) {\n    drawer.style.cssText = 'display:block; position:fixed; z-index:300; background:#111114; border:1px solid #222228; bottom:0; left:0; right:0; border-radius:16px 16px 0 0; border-bottom:none; max-height:60vh; overflow:hidden; display:flex; flex-direction:column;';\n    handle.style.display = 'block';\n    body.style.maxHeight = 'calc(60vh - 60px)';\n  } else {\n    drawer.style.cssText = 'display:block; position:fixed; z-index:300; background:#111114; border:1px solid #222228; top:48px; left:0; width:320px; height:calc(100vh - 48px); overflow:hidden; display:flex; flex-direction:column;';\n    handle.style.display = 'none';\n    body.style.maxHeight = 'calc(100vh - 108px)';\n    body.style.overflowY = 'auto';\n  }\n}\nfunction closeUnifiedDrawer() { document.getElementById('unified-drawer').style.display = 'none'; }\nfunction openDrawer(session) { openUnifiedDrawer(session); }\nfunction closeDrawer() { closeUnifiedDrawer(); }\nfunction openAlphaSheet(session) { openUnifiedDrawer(session); }\nfunction closeAlphaSheet() { closeUnifiedDrawer(); }\nfunction openCostOverride() { document.getElementById('cost-override-modal').style.display = 'flex'; }\nfunction closeCostOverride() { document.getElementById('cost-override-modal').style.display = 'none'; }\nfunction saveCostOverride() {\n  const amount = parseFloat(document.getElementById('cost-override-input').value);\n  if (isNaN(amount)) return;\n  fetch('/api/cost-override', { method: 'POST', headers: { ...API_HEADERS, 'Content-Type': 'application/json' }, body: JSON.stringify({ amount }) })\n    .then(r => r.json()).then(() => { window._costOverride = amount; renderAlpha(); closeCostOverride(); });\n}\n(function loadOverride() {\n  fetch('/api/cost-override', { headers: API_HEADERS }).then(r => r.json()).then(data => {\n    if (data.amount) { window._costOverride = data.amount; window._overrideTs = data.updated_at; }\n  });\n})();\nfunction fmtTs(ts) {\n    if (!ts) return '—';\n    const d = new Date(ts * 1000);\n    return d.getHours().toString().padStart(2, '0') + ':' + d.getMinutes().toString().padStart(2, '0') + ':' + d.getSeconds().toString().padStart(2, '0');\n}\nfunction abbreviate(s, n) {\n    if (!s) return '—';\n    return s.length > n ? s.substring(0, n - 3) + '...' : s;\n}\n\n// ---- Screenshot (dom-to-image) ----\nfunction downloadScreenshot() {\n  const btns = [document.getElementById('screenshot-btn'), document.getElementById('screenshot-btn-mobile')].filter(Boolean);\n  btns.forEach(b => { b.disabled = true; b._orig = b.innerHTML; b.innerHTML = '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z\"/><circle cx=\"12\" cy=\"13\" r=\"4\"/></svg>'; });\n  const restore = () => btns.forEach(b => { b.innerHTML = b._orig; b.disabled = false; });\n  domtoimage.toPng(document.body, {\n    width: document.body.scrollWidth,\n    height: document.body.scrollHeight,\n    bgcolor: '#0A0A0B'\n  }).then(function(dataUrl) {\n    const a = document.createElement('a');\n    a.download = 'olympus-' + new Date().toISOString().slice(0,16).replace(/[T:]/g,'-') + '.png';\n    a.href = dataUrl;\n    a.click();\n    restore();\n  }).catch(function(err) {\n    console.error('screenshot failed:', err);\n    restore();\n  });\n}\n\n// ── Tool Calls polling ──────────────────────────────────────────────────────\nasync function fetchToolCalls() {\n  try {\n    const res = await fetch('/api/tool-calls?limit=50', {\n      headers: { 'Authorization': 'Bearer olympus2026' }\n    });\n    if (!res.ok) return;\n    const rows = await res.json();\n\n    // Popola sia desktop che mobile\n    const targets = [\n      { tbody: document.getElementById('tool-calls-tbody-desktop'), empty: document.getElementById('tool-calls-empty-desktop') },\n      { tbody: document.getElementById('tool-calls-tbody'), empty: document.getElementById('tool-calls-empty') }\n    ];\n\n    targets.forEach(({ tbody, empty }) => {\n      if (!tbody) return;\n      if (!rows || rows.length === 0) {\n        tbody.innerHTML = '';\n        if (empty) empty.style.display = 'block';\n        return;\n      }\n      if (empty) empty.style.display = 'none';\n      tbody.innerHTML = rows.map(r => {\n        const dt = new Date(r.ts);\n        const ts = dt.toTimeString().slice(0,8);\n        const session = (r.session_id || '').split(':').pop().slice(0, 18);\n        const statusClass = r.status === 'ok' ? 'tc-ok' : 'tc-error';\n        const dur = r.duration_ms != null ? r.duration_ms + 'ms' : '—';\n        return `<tr>\n          <td style=\"color:#555;\">${ts}</td>\n          <td title=\"${r.session_id}\">${session}</td>\n          <td style=\"color:#e0e0e0;\">${r.tool_name}</td>\n          <td class=\"${statusClass}\">${r.status || '—'}</td>\n          <td style=\"text-align:right; color:#777;\">${dur}</td>\n        </tr>`;\n      }).join('');\n    });\n  } catch(e) { /* silent */ }\n}\nasync function fetchCrons() {\n  try {\n    const res = await fetch('/api/crons', { headers: { 'Authorization': 'Bearer olympus2026' } });\n    if (!res.ok) return;\n    const jobs = await res.json();\n    \n    function fmtDur(ms) {\n      if (!ms && ms !== 0) return '—';\n      if (ms < 1000) return ms + 'ms';\n      return (ms/1000).toFixed(1) + 's';\n    }\n    \n    function fmtNext(ms) {\n      if (!ms) return '—';\n      const diff = ms - Date.now();\n      if (diff <= 0) return 'now';\n      const m = Math.floor(diff / 60000);\n      const h = Math.floor(diff / 3600000);\n      const d = Math.floor(diff / 86400000);\n      if (d >= 1) return 'in ' + d + 'd';\n      if (h >= 1) return 'in ' + h + 'h';\n      return 'in ' + m + 'm';\n    }\n    \n    function fmtLastRun(ms) {\n      if (!ms) return '—';\n      const d = new Date(ms);\n      return d.toLocaleTimeString('en-GB', {hour:'2-digit',minute:'2-digit'});\n    }\n    \n    // Sort: enabled with errors first, then enabled ok, then disabled\n    const sorted = [...jobs].sort((a, b) => {\n      const aErr = a.enabled && (a.state?.consecutiveErrors || 0) > 0;\n      const bErr = b.enabled && (b.state?.consecutiveErrors || 0) > 0;\n      if (aErr && !bErr) return -1;\n      if (!aErr && bErr) return 1;\n      if (a.enabled && !b.enabled) return -1;\n      if (!a.enabled && b.enabled) return 1;\n      return 0;\n    });\n    \n    function buildRows(tbody, emptyEl) {\n      tbody.innerHTML = '';\n      if (!sorted.length) { emptyEl.style.display = ''; return; }\n      emptyEl.style.display = 'none';\n      sorted.forEach(job => {\n        const st = job.state || {};\n        const hasErrors = (st.consecutiveErrors || 0) > 0;\n        const tr = document.createElement('tr');\n        if (hasErrors) tr.classList.add('cron-row-error');\n        \n        let statusCell = '';\n        let statusClass = '';\n        if (!job.enabled) {\n          statusCell = '—'; statusClass = 'cron-disabled';\n        } else if (st.lastRunStatus === 'ok') {\n          statusCell = '✓'; statusClass = 'cron-ok';\n        } else if (st.lastRunStatus === 'error') {\n          statusCell = '✗'; statusClass = 'cron-error';\n        } else {\n          statusCell = '—'; statusClass = 'cron-disabled';\n        }\n        \n        tr.innerHTML = `\n          <td class=\"cron-name\">${job.name || job.id?.substring(0,8) || '—'}</td>\n          <td class=\"cron-schedule\">${job.schedule?.expr || '—'}</td>\n          <td>${fmtLastRun(st.lastRunAtMs)}</td>\n          <td class=\"${statusClass}\">${statusCell}</td>\n          <td style=\"text-align:right\">${fmtDur(st.lastDurationMs)}</td>\n          <td style=\"text-align:right\">${fmtNext(st.nextRunAtMs)}</td>\n        `;\n        tbody.appendChild(tr);\n      });\n    }\n    \n    const tbodyDesktop = document.getElementById('crons-tbody-desktop');\n    const emptyDesktop = document.getElementById('crons-empty-desktop');\n    const tbodyMobile = document.getElementById('crons-tbody');\n    const emptyMobile = document.getElementById('crons-empty');\n    \n    if (tbodyDesktop) buildRows(tbodyDesktop, emptyDesktop);\n    if (tbodyMobile) buildRows(tbodyMobile, emptyMobile);\n    \n  } catch(e) {}\n}\nsetInterval(fetchCrons, 30000);\nfetchCrons();\n\nsetInterval(fetchToolCalls, 15000);\nfetchToolCalls();\n\n// ===================== SYSTEM METRICS =====================\nlet sysSparklineData = [];\nconst SYS_SPARKLINE_W = 120, SYS_SPARKLINE_H = 28;\nconst M_SYS_SPARKLINE_W = 260, M_SYS_SPARKLINE_H = 36;\n\nfunction cpuColor(pct) {\n  if (pct > 85) return 'red';\n  if (pct > 60) return 'yellow';\n  return 'green';\n}\n\nfunction renderSparkline(containerId, data, width, height) {\n  const el = document.getElementById(containerId);\n  if (!el) return;\n  el.innerHTML = '';\n  if (!data || data.length < 2) return;\n  const svg = d3.select(el).append('svg')\n    .attr('width', width).attr('height', height);\n  const xScale = d3.scaleLinear().domain([0, data.length - 1]).range([0, width]);\n  const yScale = d3.scaleLinear().domain([0, 100]).range([height, 0]);\n  const line = d3.line()\n    .x((d, i) => xScale(i))\n    .y(d => yScale(d))\n    .curve(d3.curveMonotoneX);\n  svg.append('path')\n    .datum(data)\n    .attr('fill', 'none')\n    .attr('stroke', '#B87333')\n    .attr('stroke-width', 1.5)\n    .attr('d', line);\n  // last point dot\n  const lastVal = data[data.length - 1];\n  const color = cpuColor(lastVal);\n  const dotColors = { green: '#22c55e', yellow: '#eab308', red: '#ef4444' };\n  svg.append('circle')\n    .attr('cx', xScale(data.length - 1))\n    .attr('cy', yScale(lastVal))\n    .attr('r', 2.5)\n    .attr('fill', dotColors[color] || '#B87333');\n}\n\nasync function fetchSystemMetrics() {\n  try {\n    const res = await fetch('/api/metrics?limit=60', { headers: API_HEADERS });\n    if (!res.ok) return;\n    const data = await res.json();\n    if (!data.latest) return;\n    const { latest, history, stats_24h } = data;\n\n    // Update sparkline data\n    sysSparklineData = history.map(h => h.cpu || 0);\n\n    // --- Desktop widget ---\n    const cpu = latest.cpu || 0;\n    const ramPct = latest.ram_total_mb > 0 ? Math.round(latest.ram_used_mb / latest.ram_total_mb * 100) : 0;\n    const diskPct = latest.disk_total_gb > 0 ? Math.round(latest.disk_used_gb / latest.disk_total_gb * 100) : 0;\n    const cc = cpuColor(cpu);\n\n    const cpuEl = document.getElementById('sys-cpu-val');\n    if (cpuEl) {\n      cpuEl.textContent = cpu + '%';\n      cpuEl.className = 'sys-value ' + cc;\n    }\n    const ramEl = document.getElementById('sys-ram-val');\n    if (ramEl) ramEl.textContent = ramPct + '%';\n    const ramBarEl = document.getElementById('sys-ram-bar');\n    if (ramBarEl) { ramBarEl.style.width = ramPct + '%'; ramBarEl.className = 'sys-bar ' + cpuColor(ramPct > 90 ? 90 : ramPct < 60 ? 0 : 70); }\n    const ramSubEl = document.getElementById('sys-ram-sub');\n    if (ramSubEl) ramSubEl.textContent = (latest.ram_used_mb/1024).toFixed(1) + ' GB / ' + (latest.ram_total_mb/1024).toFixed(1) + ' GB';\n    const diskEl = document.getElementById('sys-disk-val');\n    if (diskEl) diskEl.textContent = diskPct + '%';\n    const diskBarEl = document.getElementById('sys-disk-bar');\n    if (diskBarEl) { diskBarEl.style.width = diskPct + '%'; diskBarEl.className = 'sys-bar ' + cpuColor(diskPct > 85 ? 90 : diskPct < 60 ? 0 : 70); }\n    const diskSubEl = document.getElementById('sys-disk-sub');\n    if (diskSubEl) diskSubEl.textContent = latest.disk_used_gb.toFixed(1) + ' GB / ' + latest.disk_total_gb.toFixed(1) + ' GB';\n    const loadEl = document.getElementById('sys-load-val');\n    if (loadEl) loadEl.textContent = (latest.load_avg || 0).toFixed(2);\n    const tsEl = document.getElementById('sys-ts');\n    if (tsEl) tsEl.textContent = new Date(latest.ts * 1000).toLocaleTimeString();\n\n    // Sparkline desktop\n    renderSparkline('sys-sparkline', sysSparklineData, SYS_SPARKLINE_W, SYS_SPARKLINE_H);\n\n    // Alert badges desktop\n    const cpuAlert = document.getElementById('sys-cpu-alert');\n    if (cpuAlert) cpuAlert.style.display = (cpu > 85) ? 'inline' : 'none';\n    const ramAlert = document.getElementById('sys-ram-alert');\n    if (ramAlert) ramAlert.style.display = (ramPct > 90) ? 'inline' : 'none';\n\n    // --- Mobile widget ---\n    const mCpuEl = document.getElementById('m-sys-cpu-val');\n    if (mCpuEl) { mCpuEl.textContent = cpu + '%'; mCpuEl.style.color = cc === 'red' ? 'var(--red)' : cc === 'yellow' ? '#eab308' : 'var(--green)'; }\n    const mRamEl = document.getElementById('m-sys-ram-val');\n    if (mRamEl) mRamEl.textContent = ramPct + '%';\n    const mRamSubEl = document.getElementById('m-sys-ram-sub');\n    if (mRamSubEl) mRamSubEl.textContent = (latest.ram_used_mb/1024).toFixed(1) + ' GB / ' + (latest.ram_total_mb/1024).toFixed(1) + ' GB';\n    const mRamBarEl = document.getElementById('m-sys-ram-bar');\n    if (mRamBarEl) { mRamBarEl.style.width = ramPct + '%'; }\n    const mDiskEl = document.getElementById('m-sys-disk-val');\n    if (mDiskEl) mDiskEl.textContent = diskPct + '%';\n    const mDiskSubEl = document.getElementById('m-sys-disk-sub');\n    if (mDiskSubEl) mDiskSubEl.textContent = latest.disk_used_gb.toFixed(1) + ' GB / ' + latest.disk_total_gb.toFixed(1) + ' GB';\n    const mDiskBarEl = document.getElementById('m-sys-disk-bar');\n    if (mDiskBarEl) { mDiskBarEl.style.width = diskPct + '%'; }\n    const mLoadEl = document.getElementById('m-sys-load-val');\n    if (mLoadEl) mLoadEl.textContent = (latest.load_avg || 0).toFixed(2);\n    const mTsEl = document.getElementById('m-sys-ts');\n    if (mTsEl) mTsEl.textContent = new Date(latest.ts * 1000).toLocaleTimeString();\n\n    // Sparkline mobile\n    renderSparkline('m-sys-sparkline', sysSparklineData, M_SYS_SPARKLINE_W, M_SYS_SPARKLINE_H);\n\n    // Alert badges mobile\n    const mCpuAlert = document.getElementById('m-sys-cpu-alert');\n    if (mCpuAlert) mCpuAlert.style.display = (cpu > 85) ? 'inline' : 'none';\n    const mRamAlert = document.getElementById('m-sys-ram-alert');\n    if (mRamAlert) mRamAlert.style.display = (ramPct > 90) ? 'inline' : 'none';\n\n  } catch(e) { /* silent */ }\n}\n\nsetInterval(fetchSystemMetrics, 10000);\nfetchSystemMetrics();\n\n";
const SW_SCRIPT = "\nif ('serviceWorker' in navigator) {\n  window.addEventListener('load', () => {\n    navigator.serviceWorker.register('/sw.js').catch(() => {});\n  });\n}\n";

function loadScript(src) {
  return new Promise((resolve, reject) => {
    const existing = document.querySelector(`script[src=\"${src}\"]`);
    if (existing) {
      if (existing.dataset.loaded === '1') return resolve(existing);
      existing.addEventListener('load', () => resolve(existing), { once: true });
      existing.addEventListener('error', reject, { once: true });
      return;
    }
    const s = document.createElement('script');
    s.src = src;
    s.async = true;
    s.addEventListener('load', () => { s.dataset.loaded = '1'; resolve(s); }, { once: true });
    s.addEventListener('error', reject, { once: true });
    document.head.appendChild(s);
  });
}

export default function OlympusDashboard() {
  useEffect(() => {
    let mounted = true;
    const injected = [];

    async function boot() {
      await loadScript('https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js');
      await loadScript('https://unpkg.com/dom-to-image@2.6.0/dist/dom-to-image.min.js');
      if (!mounted) return;

      const core = document.createElement('script');
      core.text = DASHBOARD_SCRIPT;
      document.body.appendChild(core);
      injected.push(core);

      if (SW_SCRIPT && SW_SCRIPT.trim()) {
        const sw = document.createElement('script');
        sw.text = SW_SCRIPT;
        document.body.appendChild(sw);
        injected.push(sw);
      }
    }

    boot();

    return () => {
      mounted = false;
      injected.forEach((el) => el.remove());
    };
  }, []);

  return <div id="olympus-dashboard" dangerouslySetInnerHTML={{ __html: DASHBOARD_HTML }} />;
}
