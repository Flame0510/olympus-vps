import Database from 'better-sqlite3';
import { NextResponse } from 'next/server';
const DB_PATH = process.env.OLYMPUS_DB || '/data/olympus/events.db';
const TOKEN = process.env.OLYMPUS_TOKEN || 'olympus2026';
export const dynamic = 'force-dynamic';
export async function GET(request) {
  const auth = request.headers.get('authorization');
  if (auth !== `Bearer ${TOKEN}`) return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
  try {
    const db = new Database(DB_PATH, { readonly: true });
    const twoDaysAgo = Math.floor(Date.now() / 1000) - 2 * 24 * 60 * 60;
    const agents = db.prepare(`SELECT CASE WHEN INSTR(session_id,':')=0 THEN 'unknown' ELSE SUBSTR(session_id,INSTR(session_id,':')+1,INSTR(SUBSTR(session_id,INSTR(session_id,':')+1),':')-1) END as agent_id FROM sessions WHERE status IN ('active','idle','working') AND updated_at > ? GROUP BY agent_id ORDER BY agent_id`).all(twoDaysAgo);
    db.close();
    return NextResponse.json(agents.map(a => a.agent_id).filter(id => id && id !== 'unknown'));
  } catch (err) { return NextResponse.json({ error: err.message }, { status: 500 }); }
}
